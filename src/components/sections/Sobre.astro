---
import Icon from "../Icon.astro";
---

<section
    id="sobre"
    class="relative w-full bg-[#050505] py-32 rounded-t-[3rem] -mt-10 z-40 shadow-[0_-20px_50px_rgba(0,0,0,0.5)] overflow-hidden border-t border-white/5"
>
    <!-- Textura DS Background -->
    <div
        class="absolute inset-0 opacity-[0.4] mix-blend-overlay pointer-events-none"
        style="background-image: url('data:image/svg+xml,%3Csvg viewBox=%220 0 200 200%22 xmlns=%22http://www.w3.org/2000/svg%22%3E%3Cfilter id=%22noiseFilter%22%3E%3CfeTurbulence type=%22fractalNoise%22 baseFrequency=%220.8%22 numOctaves=%223%22 stitchTiles=%22stitch%22/%3E%3C/filter%3E%3Crect width=%22100%25%22 height=%22100%25%22 filter=%22url(%23noiseFilter)%22/%3E%3C/svg%3E');"
    >
    </div>
    <div
        class="absolute top-[-20%] right-[-10%] w-[800px] h-[800px] bg-[#FDD017]/5 blur-[150px] rounded-full pointer-events-none"
    >
    </div>

    <div class="max-w-7xl mx-auto px-6 md:px-12 relative z-10">
        <!-- Header da Seção (DS Hero Style) -->
        <div
            class="flex flex-col md:flex-row justify-between items-start md:items-end mb-24 gap-10"
        >
            <div class="sobre-title opacity-0 translate-y-12">
                <div
                    class="inline-flex items-center gap-3 px-4 py-2 rounded-full border border-white/10 bg-white/5 backdrop-blur-md mb-6 shadow-2xl"
                >
                    <span
                        class="w-2 h-2 rounded-full bg-[#FDD017] shadow-[0_0_10px_#FDD017] animate-pulse"
                    ></span>
                    <span
                        class="text-[10px] font-bold uppercase tracking-[0.2em] text-[#FDD017]"
                        >A Essência da Confiança</span
                    >
                </div>
                <h2
                    class="text-4xl md:text-6xl lg:text-[4rem] font-medium tracking-tighter text-white leading-[1.1] max-w-2xl"
                >
                    Nossa História:<br />
                    <span
                        class="text-transparent bg-clip-text bg-gradient-to-r from-[#FDD017] to-yellow-600 font-black pr-2"
                        >Evoluindo com Você</span
                    >
                </h2>
            </div>
            <div class="sobre-desc max-w-sm opacity-0 translate-y-12">
                <p
                    class="leading-relaxed text-lg font-medium text-white/60"
                >
                    Não somos apenas mantenedores. Somos parceiros
                    estratégicos para garantir que seu investimento em
                    energia solar alcance o máximo potencial de geração,
                    ano após ano.
                </p>
            </div>
        </div>

        <!-- LINHA DO TEMPO ANIMADA (GRANDIOSA) -->
        <div class="relative w-full mb-32 timeline-container pt-10">
            <!-- As Linhas (Trilhos) -->
            <div
                class="absolute left-[2.5rem] md:left-0 top-[2.5rem] md:top-[5rem] w-[1px] md:w-full h-full md:h-[1px] bg-gradient-to-b md:bg-gradient-to-r from-transparent via-white/10 to-transparent -translate-x-1/2 md:-translate-x-0 md:-translate-y-1/2 z-0"
            >
            </div>
            <div
                id="timeline-line"
                class="absolute left-[2.5rem] md:left-0 top-[2.5rem] md:top-[5rem] w-[1px] md:w-0 h-0 md:h-[1px] bg-gradient-to-b md:bg-gradient-to-r from-[#FDD017]/0 via-[#FDD017] to-[#FDD017]/0 -translate-x-1/2 md:-translate-x-0 md:-translate-y-1/2 z-10 shadow-[0_0_20px_#FDD017]"
            >
            </div>

            <!-- O Grid de Conteúdo -->
            <div
                class="grid grid-cols-1 md:grid-cols-3 gap-y-12 md:gap-y-0 gap-x-10 relative z-20"
            >
                <!-- Milestone 1 -->
                <div
                    class="timeline-node opacity-0 translate-y-12 flex flex-row md:flex-col items-start md:items-center relative group"
                >
                    <!-- Node Visual -->
                    <div
                        class="w-20 h-20 flex items-center justify-center shrink-0 relative z-20 md:mb-10"
                    >
                        <div
                            class="absolute inset-0 bg-[#FDD017]/10 group-hover:bg-[#FDD017]/30 blur-2xl rounded-full transition-all duration-700"
                        >
                        </div>
                        <div
                            class="w-14 h-14 bg-[#050505] border border-[#FDD017]/50 group-hover:border-[#FDD017] rounded-full shadow-[0_0_15px_rgba(253,208,23,0.2)] relative flex items-center justify-center transition-all duration-500 overflow-hidden z-10 group-hover:scale-110"
                        >
                            <div
                                class="absolute inset-0 bg-gradient-to-b from-[#FDD017]/10 to-transparent opacity-100 transition-opacity duration-500"
                            >
                            </div>
                            <div
                                class="w-4 h-4 bg-[#FDD017] rounded-full transition-colors duration-500 animate-pulse shadow-[0_0_15px_#FDD017]"
                            >
                            </div>
                        </div>
                    </div>

                    <!-- Grandioso Card -->
                    <div
                        class="flex-1 w-full relative z-10 flex flex-col items-start md:items-center text-left md:text-center bg-[#111111]/40 border border-white/5 backdrop-blur-2xl rounded-[2.5rem] p-8 md:p-10 transition-all duration-700 md:group-hover:-translate-y-4 group-hover:bg-[#151515]/80 group-hover:border-white/10 group-hover:shadow-[0_20px_40px_rgba(0,0,0,0.8),0_0_30px_rgba(253,208,23,0.05)] overflow-hidden mt-2 md:mt-0 ml-4 md:ml-0"
                    >
                        <!-- Efeito de borda superior -->
                        <div
                            class="absolute top-0 left-0 md:left-1/2 md:-translate-x-1/2 w-1/2 h-[1px] bg-gradient-to-r from-transparent via-white/20 group-hover:via-[#FDD017] to-transparent transition-colors duration-700"
                        >
                        </div>

                        <!-- Ghost Year -->
                        <div
                            class="absolute -top-4 md:-top-2 right-4 md:right-auto md:left-1/2 md:-translate-x-1/2 text-7xl md:text-8xl font-black text-white/[0.12] group-hover:text-white/[0.25] transition-colors duration-700 pointer-events-none select-none"
                        >
                            2018
                        </div>

                        <!-- Conteúdo do Card -->
                        <div class="relative z-10 w-full pt-2">
                            <div
                                class="inline-flex items-center gap-2 mb-4 md:justify-center w-full"
                            >
                                <Icon
                                    name="compass"
                                    class="w-4 h-4 text-[#FDD017]/60 group-hover:text-[#FDD017] transition-colors duration-500"
                                />
                                <span
                                    class="text-[10px] font-bold uppercase tracking-[0.2em] text-[#FDD017]"
                                    >Origem</span
                                >
                            </div>
                            <h3
                                class="text-2xl font-medium text-white mb-3 group-hover:text-[#FDD017] transition-colors duration-500"
                            >
                                A Fundação
                            </h3>
                            <p
                                class="text-white/50 text-sm font-medium leading-relaxed group-hover:text-white/70 transition-colors duration-500"
                            >
                                Nascimento da visão de revolucionar a
                                manutenção solar através de engenharia
                                de precisão e dados concretos.
                            </p>
                        </div>
                    </div>
                </div>

                <!-- Milestone 2 -->
                <div
                    class="timeline-node opacity-0 translate-y-12 flex flex-row md:flex-col items-start md:items-center relative group"
                >
                    <!-- Node Visual -->
                    <div
                        class="w-20 h-20 flex items-center justify-center shrink-0 relative z-20 md:mb-10"
                    >
                        <div
                            class="absolute inset-0 bg-[#FDD017]/10 group-hover:bg-[#FDD017]/30 blur-2xl rounded-full transition-all duration-700"
                        >
                        </div>
                        <div
                            class="w-14 h-14 bg-[#050505] border border-[#FDD017]/50 group-hover:border-[#FDD017] rounded-full shadow-[0_0_15px_rgba(253,208,23,0.2)] relative flex items-center justify-center transition-all duration-500 overflow-hidden z-10 group-hover:scale-110"
                        >
                            <div
                                class="absolute inset-0 bg-gradient-to-b from-[#FDD017]/10 to-transparent opacity-100 transition-opacity duration-500"
                            >
                            </div>
                            <div
                                class="w-4 h-4 bg-[#FDD017] rounded-full transition-colors duration-500 animate-pulse shadow-[0_0_15px_#FDD017]"
                            >
                            </div>
                        </div>
                    </div>

                    <!-- Grandioso Card -->
                    <div
                        class="flex-1 w-full relative z-10 flex flex-col items-start md:items-center text-left md:text-center bg-[#111111]/40 border border-white/5 backdrop-blur-2xl rounded-[2.5rem] p-8 md:p-10 transition-all duration-700 md:group-hover:-translate-y-4 group-hover:bg-[#151515]/80 group-hover:border-white/10 group-hover:shadow-[0_20px_40px_rgba(0,0,0,0.8),0_0_30px_rgba(253,208,23,0.05)] overflow-hidden mt-2 md:mt-0 ml-4 md:ml-0"
                    >
                        <!-- Efeito de borda superior -->
                        <div
                            class="absolute top-0 left-0 md:left-1/2 md:-translate-x-1/2 w-1/2 h-[1px] bg-gradient-to-r from-transparent via-white/20 group-hover:via-[#FDD017] to-transparent transition-colors duration-700"
                        >
                        </div>

                        <!-- Ghost Year -->
                        <div
                            class="absolute -top-4 md:-top-2 right-4 md:right-auto md:left-1/2 md:-translate-x-1/2 text-7xl md:text-8xl font-black text-white/[0.12] group-hover:text-white/[0.25] transition-colors duration-700 pointer-events-none select-none"
                        >
                            2021
                        </div>

                        <!-- Conteúdo do Card -->
                        <div class="relative z-10 w-full pt-2">
                            <div
                                class="inline-flex items-center gap-2 mb-4 md:justify-center w-full"
                            >
                                <Icon
                                    name="trending-up"
                                    class="w-4 h-4 text-[#FDD017]/60 group-hover:text-[#FDD017] transition-colors duration-500"
                                />
                                <span
                                    class="text-[10px] font-bold uppercase tracking-[0.2em] text-[#FDD017]"
                                    >Evolução</span
                                >
                            </div>
                            <h3
                                class="text-2xl font-medium text-white mb-3 group-hover:text-[#FDD017] transition-colors duration-500"
                            >
                                Expansão
                            </h3>
                            <p
                                class="text-white/50 text-sm font-medium leading-relaxed group-hover:text-white/70 transition-colors duration-500"
                            >
                                Incorporação de termografia avançada e
                                monitoramento analítico, elevando o
                                diagnóstico ao nível cirúrgico.
                            </p>
                        </div>
                    </div>
                </div>

                <!-- Milestone 3 -->
                <div
                    class="timeline-node opacity-0 translate-y-12 flex flex-row md:flex-col items-start md:items-center relative group"
                >
                    <!-- Node Visual -->
                    <div
                        class="w-20 h-20 flex items-center justify-center shrink-0 relative z-20 md:mb-10"
                    >
                        <div
                            class="absolute inset-0 bg-[#FDD017]/10 group-hover:bg-[#FDD017]/30 blur-2xl rounded-full transition-all duration-700"
                        >
                        </div>
                        <div
                            class="w-14 h-14 bg-[#050505] border border-[#FDD017]/50 group-hover:border-[#FDD017] rounded-full shadow-[0_0_15px_rgba(253,208,23,0.2)] relative flex items-center justify-center transition-all duration-500 overflow-hidden z-10 group-hover:scale-110"
                        >
                            <div
                                class="absolute inset-0 bg-gradient-to-b from-[#FDD017]/10 to-transparent opacity-100 transition-opacity duration-500"
                            >
                            </div>
                            <div
                                class="w-4 h-4 bg-[#FDD017] rounded-full transition-colors duration-500 animate-pulse shadow-[0_0_15px_#FDD017]"
                            >
                            </div>
                        </div>
                    </div>

                    <!-- Grandioso Card -->
                    <div
                        class="flex-1 w-full relative z-10 flex flex-col items-start md:items-center text-left md:text-center bg-[#111111]/40 border border-white/5 backdrop-blur-2xl rounded-[2.5rem] p-8 md:p-10 transition-all duration-700 md:group-hover:-translate-y-4 group-hover:bg-[#151515]/80 group-hover:border-white/10 group-hover:shadow-[0_20px_40px_rgba(0,0,0,0.8),0_0_30px_rgba(253,208,23,0.05)] overflow-hidden mt-2 md:mt-0 ml-4 md:ml-0"
                    >
                        <!-- Efeito de borda superior -->
                        <div
                            class="absolute top-0 left-0 md:left-1/2 md:-translate-x-1/2 w-1/2 h-[1px] bg-gradient-to-r from-transparent via-[#FDD017] to-transparent transition-colors duration-700"
                        >
                        </div>

                        <!-- Ghost Year -->
                        <div
                            class="absolute -top-4 md:-top-2 right-4 md:right-auto md:left-1/2 md:-translate-x-1/2 text-7xl md:text-8xl font-black text-[#FDD017]/[0.12] group-hover:text-[#FDD017]/[0.28] transition-colors duration-700 pointer-events-none select-none"
                        >
                            2024
                        </div>

                        <!-- Conteúdo do Card -->
                        <div class="relative z-10 w-full pt-2">
                            <div
                                class="inline-flex items-center gap-2 mb-4 md:justify-center w-full"
                            >
                                <Icon
                                    name="award"
                                    class="w-4 h-4 text-[#FDD017] transition-colors duration-500"
                                />
                                <span
                                    class="text-[10px] font-bold uppercase tracking-[0.2em] text-[#FDD017]"
                                    >Presente</span
                                >
                            </div>
                            <h3
                                class="text-2xl font-medium text-white mb-3 group-hover:text-[#FDD017] transition-colors duration-500"
                            >
                                Excelência
                            </h3>
                            <p
                                class="text-white/50 text-sm font-medium leading-relaxed group-hover:text-white/70 transition-colors duration-500"
                            >
                                Consolidação como referência técnica,
                                blindando e otimizando UFV's de alta
                                complexidade pelo Brasil.
                            </p>
                        </div>
                    </div>
                </div>
            </div>
        </div>

        <!-- MISSÃO E VALORES (GRANDIOSO) -->
        <div
            class="grid grid-cols-1 lg:grid-cols-3 gap-8 relative z-20"
        >
            <!-- Missão (Span 2 Columns, Cinematic Background) -->
            <div
                class="lg:col-span-2 relative overflow-hidden bg-gradient-to-br from-[#0A0A0A] to-[#000000] border border-white/10 rounded-[2.5rem] p-10 md:p-14 group missao-block opacity-0 translate-y-12 shadow-[0_20px_50px_rgba(0,0,0,0.5)] transition-all duration-700 hover:shadow-[0_20px_60px_rgba(253,208,23,0.15)] hover:border-white/20"
            >
                <!-- Fundo Dinâmico e Brilho -->
                <div
                    class="absolute inset-0 bg-[radial-gradient(ellipse_at_top_right,rgba(253,208,23,0.15),transparent_50%)] opacity-50 group-hover:opacity-100 transition-opacity duration-1000"
                >
                </div>
                <div
                    class="absolute -bottom-32 -left-32 w-96 h-96 bg-[#FDD017]/10 blur-[100px] rounded-full pointer-events-none group-hover:bg-[#FDD017]/20 transition-colors duration-1000"
                >
                </div>

                <div
                    class="relative z-10 flex flex-col h-full justify-center"
                >
                    <div class="flex items-center gap-4 mb-10">
                        <div
                            class="w-16 h-16 bg-white/5 border border-white/10 backdrop-blur-xl rounded-2xl flex items-center justify-center shadow-2xl group-hover:bg-[#FDD017]/20 group-hover:border-[#FDD017]/50 transition-all duration-700 group-hover:scale-110 group-hover:rotate-6"
                        >
                            <Icon
                                name="target"
                                class="w-8 h-8 text-[#FDD017]"
                            />
                        </div>
                        <div>
                            <h4
                                class="text-xs font-bold tracking-[0.3em] uppercase text-[#FDD017]/80"
                            >
                                Nossa Missão
                            </h4>
                        </div>
                    </div>

                    <p
                        class="text-3xl md:text-5xl lg:text-[3.5rem] font-medium text-white leading-[1.15] tracking-tight"
                    >
                        Maximizamos o retorno do seu investimento
                        protegendo e <span
                            class="relative inline-block mx-1 px-3 py-1 group-hover:px-5 transition-all duration-500"
                            ><span
                                class="absolute inset-0 bg-[#FDD017]/10 transform -skew-x-12 transition-all duration-500 group-hover:bg-[#FDD017] rounded-lg border border-[#FDD017]/30 group-hover:border-[#FDD017]"
                            ></span><span
                                class="font-black italic text-[#FDD017] group-hover:text-black transition-colors duration-500 relative z-10"
                                >blindando</span
                            >
                        </span> sua usina solar.
                    </p>
                </div>
            </div>

            <!-- Valores Verticais -->
            <div class="lg:col-span-1 flex flex-col gap-8">
                <!-- Valor 1: Parceria -->
                <div
                    class="flex-1 bg-white/5 border border-white/10 backdrop-blur-md rounded-[2.5rem] p-8 md:p-10 valor-item opacity-0 translate-y-12 transition-all duration-500 hover:-translate-y-2 hover:bg-white/10 hover:border-[#FDD017]/30 hover:shadow-[0_20px_40px_rgba(0,0,0,0.5),0_0_20px_rgba(253,208,23,0.1)] group relative overflow-hidden"
                >
                    <div
                        class="absolute inset-0 bg-gradient-to-t from-[#FDD017]/5 to-transparent opacity-0 group-hover:opacity-100 transition-opacity duration-500"
                    >
                    </div>
                    <div class="relative z-10">
                        <div
                            class="w-14 h-14 bg-white/5 border border-white/10 rounded-full flex items-center justify-center mb-6 group-hover:scale-110 transition-transform duration-500 group-hover:bg-[#FDD017]/20 group-hover:border-[#FDD017]/50"
                        >
                            <Icon
                                name="handshake"
                                class="w-6 h-6 text-[#FDD017]"
                            />
                        </div>
                        <h4
                            class="text-2xl font-medium text-white mb-4 group-hover:text-[#FDD017] transition-colors duration-500"
                        >
                            Parceria Transparente
                        </h4>
                        <p
                            class="text-sm text-white/60 font-medium leading-relaxed group-hover:text-white/80 transition-colors duration-300"
                        >
                            Agimos com integridade brutal. Mostramos o
                            problema, a solução e os dados reais de ganho
                            de performance. Sem letras miúdas.
                        </p>
                    </div>
                </div>

                <!-- Valor 2: Inteligência -->
                <div
                    class="flex-1 bg-white/5 border border-white/10 backdrop-blur-md rounded-[2.5rem] p-8 md:p-10 valor-item opacity-0 translate-y-12 transition-all duration-500 hover:-translate-y-2 hover:bg-white/10 hover:border-[#FDD017]/30 hover:shadow-[0_20px_40px_rgba(0,0,0,0.5),0_0_20px_rgba(253,208,23,0.1)] group relative overflow-hidden"
                >
                    <div
                        class="absolute inset-0 bg-gradient-to-t from-[#FDD017]/5 to-transparent opacity-0 group-hover:opacity-100 transition-opacity duration-500"
                    >
                    </div>
                    <div class="relative z-10">
                        <div
                            class="w-14 h-14 bg-white/5 border border-white/10 rounded-full flex items-center justify-center mb-6 group-hover:scale-110 transition-transform duration-500 group-hover:bg-[#FDD017]/20 group-hover:border-[#FDD017]/50"
                        >
                            <Icon
                                name="brain-circuit"
                                class="w-6 h-6 text-[#FDD017]"
                            />
                        </div>
                        <h4
                            class="text-2xl font-medium text-white mb-4 group-hover:text-[#FDD017] transition-colors duration-500"
                        >
                            Inteligência Técnica
                        </h4>
                        <p
                            class="text-sm text-white/60 font-medium leading-relaxed group-hover:text-white/80 transition-colors duration-300"
                        >
                            Não damos "jeitinhos". Aplicamos engenharia
                            de precisão e conhecimento técnico profundo
                            na raiz do problema.
                        </p>
                    </div>
                </div>
    </div>
</section>

<style>
    /* =============================================
       PERFORMANCE FIX: Isola a seção Sobre do
       solar-glow-wrapper (mix-blend-mode: screen)
       que causa flickering no mobile.
       ============================================= */
    #sobre {
        /* Cria um novo stacking context isolado.
           Isso impede que o mix-blend-mode: screen
           do solar-glow-wrapper recompute pixels
           contra o background desta seção, eliminando
           o flicker preto/colorido no mobile. */
        isolation: isolate;
    }

    /* =============================================
       MOBILE: Estado "hover ativo" permanente
       + Otimizações de GPU para eliminar flickering
       ============================================= */
    @media (max-width: 767px) {

        /* --- PERFORMANCE: Eliminar efeitos pesados --- */

        /* Textura SVG noise: muito cara com mix-blend-overlay no mobile */
        #sobre > div:first-child {
            display: none !important;
        }

        /* Blob de glow decorativo: reduzir blur massivo de 150px */
        #sobre > div:nth-child(2) {
            filter: blur(80px) !important;
            opacity: 0.3 !important;
        }

        /* Desativar backdrop-blur nos cards (desnecessário em bg sólido escuro) */
        #sobre .backdrop-blur-2xl,
        #sobre .backdrop-blur-xl,
        #sobre .backdrop-blur-md {
            -webkit-backdrop-filter: none !important;
            backdrop-filter: none !important;
        }

        /* Parar animações pulse contínuas nos nodes da timeline */
        .timeline-node .animate-pulse {
            animation: none !important;
        }

        /* Promover a seção inteira para a GPU de forma estável */
        #sobre {
            transform: translateZ(0);
            -webkit-transform: translateZ(0);
            will-change: auto;
        }

        /* --- MISSÃO BLOCK --- */
        .missao-block {
            box-shadow: 0 20px 60px rgba(253, 208, 23, 0.15) !important;
            border-color: rgba(255,255,255,0.20) !important;
            -webkit-backdrop-filter: none !important;
            backdrop-filter: none !important;
        }
        /* Radial glow fundo sempre visível */
        .missao-block > div:first-child {
            opacity: 1 !important;
        }
        /* Glow blur do fundo: reduzir de 100px para algo mais leve */
        .missao-block > div:nth-child(2) {
            background-color: rgba(253, 208, 23, 0.20) !important;
            filter: blur(60px) !important;
        }
        /* Ícone Target */
        .missao-block .group-hover\:bg-\[\#FDD017\]\/20 {
            background-color: rgba(253, 208, 23, 0.20) !important;
        }
        .missao-block .group-hover\:border-\[\#FDD017\]\/50 {
            border-color: rgba(253, 208, 23, 0.50) !important;
        }
        /* "blindando" highlight sempre ativo */
        .missao-block .group-hover\:bg-\[\#FDD017\] {
            background-color: #FDD017 !important;
        }
        .missao-block .group-hover\:border-\[\#FDD017\] {
            border-color: #FDD017 !important;
        }
        .missao-block .group-hover\:text-black {
            color: #000000 !important;
        }

        /* --- VALOR ITEMS --- */
        .valor-item {
            background-color: rgba(255, 255, 255, 0.10) !important;
            border-color: rgba(253, 208, 23, 0.30) !important;
            box-shadow: 0 20px 40px rgba(0,0,0,0.5), 0 0 20px rgba(253,208,23,0.1) !important;
            -webkit-backdrop-filter: none !important;
            backdrop-filter: none !important;
        }
        /* Gradient de fundo sempre visível */
        .valor-item > div:first-child {
            opacity: 1 !important;
        }
        .valor-item .group-hover\:bg-\[\#FDD017\]\/20 {
            background-color: rgba(253, 208, 23, 0.20) !important;
        }
        .valor-item .group-hover\:border-\[\#FDD017\]\/50 {
            border-color: rgba(253, 208, 23, 0.50) !important;
        }
        .valor-item .group-hover\:text-\[\#FDD017\] {
