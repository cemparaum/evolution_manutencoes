---
// Header.astro
---

<nav
    class="relative z-50 w-full px-6 md:px-12 py-8 flex justify-between items-center opacity-0"
    id="nav-animate"
>
    <!-- Brand Logo -->
    <div
        class="relative inline-flex items-center justify-center transform transition-transform hover:scale-105"
    >
        <!-- Círculo branco ao fundo para destacar o raio preto vazado do SVG -->
        <div
            class="absolute w-[45%] h-[45%] bg-[#F8F5ED] rounded-full z-0"
        >
        </div>
        <img
            src="/evolution_manutencoes/raw_file/LOGOBRUTOsvg.svg"
            alt="Evolution Logo"
            class="relative z-10 h-12 md:h-16 lg:h-20 object-contain filter drop-shadow-lg"
        />
    </div>

    <!-- Menu Links (Desktop) -->
    <div
        class="hidden md:flex gap-8 text-[11px] font-extrabold tracking-[0.2em] text-white/50 uppercase"
    >
        <a href="#" class="hover:text-[#FDD017] transition-colors">Início</a>
        <a
            href="#diferenciais"
            class="hover:text-[#FDD017] transition-colors"
            >Diferenciais</a
        >
        <a
            href="#servicos"
            class="hover:text-[#FDD017] transition-colors"
            >Serviços</a
        >
        <a
            href="#sobre"
            class="hover:text-[#FDD017] transition-colors"
            >Sobre Nós</a
        >
        <a
            href="#contato"
            class="hover:text-[#FDD017] transition-colors">Contato</a
        >
    </div>

    <!-- Hamburger Button -->
    <button
        id="mobile-menu-btn"
        aria-label="Abrir menu de navegação"
        class="md:hidden text-[#FDD017] p-2 focus:outline-none hover:scale-110 transition-transform"
    >
        <svg
            xmlns="http://www.w3.org/2000/svg"
            class="w-8 h-8"
            fill="none"
            viewBox="0 0 24 24"
            stroke="currentColor"
            stroke-width="2"
        >
            <path
                stroke-linecap="round"
                stroke-linejoin="round"
                d="M4 6h16M4 12h16M4 18h16"
            ></path>
        </svg>
    </button>
</nav>

<!-- Mobile Menu Overlay -->
<div
    id="mobile-menu"
    class="fixed inset-0 bg-[#000000]/60 z-[60] hidden flex-col items-center justify-center backdrop-blur-lg transition-all duration-300 opacity-0 translate-y-[-20px]"
>
    <button
        id="close-menu-btn"
        aria-label="Fechar menu de navegação"
        class="absolute top-8 right-6 text-[#FDD017] p-2 focus:outline-none hover:scale-110 transition-transform"
    >
        <svg
            xmlns="http://www.w3.org/2000/svg"
            class="w-10 h-10"
            fill="none"
            viewBox="0 0 24 24"
            stroke="currentColor"
            stroke-width="2"
        >
            <path
                stroke-linecap="round"
                stroke-linejoin="round"
                d="M6 18L18 6M6 6l12 12"
            ></path>
        </svg>
    </button>
    <div
        class="flex flex-col items-center gap-10 text-xl font-bold tracking-widest text-[#F8F5ED] uppercase"
    >
        <a
            href="#"
            class="mobile-link hover:text-[#FDD017] transition-colors"
            >Início</a
        >
        <a
            href="#diferenciais"
            class="mobile-link hover:text-[#FDD017] transition-colors"
            >Diferenciais</a
        >
        <a
            href="#servicos"
            class="mobile-link hover:text-[#FDD017] transition-colors"
            >Serviços</a
        >
        <a
            href="#sobre"
            class="mobile-link hover:text-[#FDD017] transition-colors"
            >Sobre Nós</a
        >
        <a
            href="#contato"
            class="mobile-link hover:text-[#FDD017] transition-colors"
            >Contato</a
        >
    </div>
</div>

<script>
    // Mobile Menu Toggle
    const mobileBtn = document.getElementById("mobile-menu-btn");
    const closeBtn = document.getElementById("close-menu-btn");
    const mobileMenu = document.getElementById("mobile-menu");
    const mobileLinks = document.querySelectorAll(".mobile-link");

    function openMenu() {
        if (!mobileMenu) return;
        mobileMenu.classList.remove("hidden");
        mobileMenu.classList.add("flex");
        requestAnimationFrame(() => {
            mobileMenu.classList.remove(
                "opacity-0",
                "translate-y-[-20px]"
            );
        });
        document.body.style.overflow = "hidden"; // prevent scrolling
    }

    function closeMenu() {
        if (!mobileMenu) return;
        mobileMenu.classList.add("opacity-0", "translate-y-[-20px]");
        setTimeout(() => {
            mobileMenu.classList.add("hidden");
            mobileMenu.classList.remove("flex");
            document.body.style.overflow = ""; // allow scrolling
        }, 300);
    }

    if (mobileBtn) mobileBtn.addEventListener("click", openMenu);
    if (closeBtn) closeBtn.addEventListener("click", closeMenu);
    mobileLinks.forEach((link) =>
        link.addEventListener("click", closeMenu)
    );

    // Close when clicking the frosted background (overlay)
    if (mobileMenu) {
        mobileMenu.addEventListener("click", (e) => {
            if (e.target === mobileMenu) {
                closeMenu();
            }
        });
    }
</script>
