---
import Icon from "../Icon.astro";
---

<footer
    class="relative z-50 w-full bg-[#000000] text-[#F8F5ED] pt-20 pb-8 overflow-hidden border-t border-white/5"
>
    <!-- Animação de Fundo -->
    <div
        class="absolute inset-0 pointer-events-none overflow-hidden opacity-20"
    >
        <div
            class="absolute bottom-[-20%] left-[20%] w-[500px] h-[500px] bg-[#FDD017]/5 blur-[100px] rounded-full mix-blend-screen animate-pulse-subtle"
        >
        </div>
    </div>

    <div class="max-w-7xl mx-auto px-6 md:px-12 relative z-10">
        <div
            class="grid grid-cols-1 md:grid-cols-2 lg:grid-cols-3 gap-12 lg:gap-8 mb-16"
        >
            <!-- Coluna 1: Logo e Descrição -->
            <div
                class="flex flex-col items-start footer-col opacity-0 translate-y-8"
            >
                <div
                    class="relative inline-flex items-center justify-center transform transition-transform hover:scale-105 mb-6 group"
                >
                    <div
                        class="absolute w-[45%] h-[45%] bg-[#F8F5ED] rounded-full z-0 group-hover:shadow-[0_0_20px_#FDD017] transition-shadow duration-500 animate-pulse-subtle"
                    >
                    </div>
                    <img
                        src="/evolution_manutencoes/raw_file/LOGOBRUTOsvg.svg"
                        alt="Evolution Logo"
                        loading="lazy"
                        class="relative z-10 h-10 md:h-12 object-contain filter drop-shadow-lg"
                    />
                </div>
                <p
                    class="text-sm text-[#F8F5ED]/70 leading-relaxed mb-6 font-medium"
                >
                    Especialistas em manutenção que transformam
                    problemas em potência e tranquilidade para sua usina
                    solar.
                </p>
                <!-- Redes Sociais -->
                <div class="flex gap-4">
                    <a
                        href="#"
                        aria-label="Acessar nosso Instagram"
                        class="w-10 h-10 rounded-full bg-[#FDD017]/10 flex items-center justify-center text-[#FDD017] hover:bg-[#FDD017] hover:text-[#000000] transition-all duration-300 hover:-translate-y-1"
                    >
                        <svg
                            xmlns="http://www.w3.org/2000/svg"
                            class="w-5 h-5"
                            viewBox="0 0 24 24"
                            fill="none"
                            stroke="currentColor"
                            stroke-width="2"
                            stroke-linecap="round"
                            stroke-linejoin="round"
                        ><rect
                                width="20"
                                height="20"
                                x="2"
                                y="2"
                                rx="5"
                                ry="5"></rect><path
                                d="M16 11.37A4 4 0 1 1 12.63 8 4 4 0 0 1 16 11.37z"
                            ></path><line
                                x1="17.5"
                                x2="17.51"
                                y1="6.5"
                                y2="6.5"></line>
                        </svg>
                    </a>
                    <a
                        href="#"
                        aria-label="Acessar nosso Facebook"
                        class="w-10 h-10 rounded-full bg-[#FDD017]/10 flex items-center justify-center text-[#FDD017] hover:bg-[#FDD017] hover:text-[#000000] transition-all duration-300 hover:-translate-y-1"
                    >
                        <svg
                            xmlns="http://www.w3.org/2000/svg"
                            class="w-5 h-5"
                            viewBox="0 0 24 24"
                            fill="none"
                            stroke="currentColor"
                            stroke-width="2"
                            stroke-linecap="round"
                            stroke-linejoin="round"
                        ><path
                                d="M18 2h-3a5 5 0 0 0-5 5v3H7v4h3v8h4v-8h3l1-4h-4V7a1 1 0 0 1 1-1h3z"
                            ></path>
                        </svg>
                    </a>
                    <a
                        href="#"
                        aria-label="Acessar nosso LinkedIn"
                        class="w-10 h-10 rounded-full bg-[#FDD017]/10 flex items-center justify-center text-[#FDD017] hover:bg-[#FDD017] hover:text-[#000000] transition-all duration-300 hover:-translate-y-1"
                    >
                        <svg
                            xmlns="http://www.w3.org/2000/svg"
                            class="w-5 h-5"
                            viewBox="0 0 24 24"
                            fill="none"
                            stroke="currentColor"
                            stroke-width="2"
                            stroke-linecap="round"
                            stroke-linejoin="round"
                        ><path
                                d="M16 8a6 6 0 0 1 6 6v7h-4v-7a2 2 0 0 0-2-2 2 2 0 0 0-2 2v7h-4v-7a6 6 0 0 1 6-6z"
                            ></path><rect
                                width="4"
                                height="12"
                                x="2"
                                y="9"></rect><circle cx="4" cy="4" r="2"
                            ></circle>
                        </svg>
                    </a>
                </div>
            </div>

            <!-- Coluna 2: Navegação Rápida -->
            <div
                class="flex flex-col footer-col opacity-0 translate-y-8"
            >
                <h4
                    class="text-lg font-black tracking-widest text-[#FDD017] uppercase mb-6"
                >
                    Navegação
                </h4>
                <ul class="flex flex-col gap-4">
                    <li>
                        <a
                            href="#"
                            class="text-[#F8F5ED]/80 font-bold hover:text-[#FDD017] transition-colors relative inline-block group"
                        >
                            Início
                            <span
                                class="absolute -bottom-1 left-0 w-0 h-0.5 bg-[#FDD017] transition-all duration-300 group-hover:w-full"
                            ></span>
                        </a>
                    </li>
                    <li>
                        <a
                            href="#diferenciais"
                            class="text-[#F8F5ED]/80 font-bold hover:text-[#FDD017] transition-colors relative inline-block group"
                        >
                            Diferenciais
                            <span
                                class="absolute -bottom-1 left-0 w-0 h-0.5 bg-[#FDD017] transition-all duration-300 group-hover:w-full"
                            ></span>
                        </a>
                    </li>
                    <li>
                        <a
                            href="#servicos"
                            class="text-[#F8F5ED]/80 font-bold hover:text-[#FDD017] transition-colors relative inline-block group"
                        >
                            Serviços
                            <span
                                class="absolute -bottom-1 left-0 w-0 h-0.5 bg-[#FDD017] transition-all duration-300 group-hover:w-full"
                            ></span>
                        </a>
                    </li>
                    <li>
                        <a
                            href="#sobre"
                            class="text-[#F8F5ED]/80 font-bold hover:text-[#FDD017] transition-colors relative inline-block group"
                        >
                            Sobre Nós
                            <span
                                class="absolute -bottom-1 left-0 w-0 h-0.5 bg-[#FDD017] transition-all duration-300 group-hover:w-full"
                            ></span>
                        </a>
                    </li>
                    <li>
                        <a
                            href="#contato"
                            class="text-[#F8F5ED]/80 font-bold hover:text-[#FDD017] transition-colors relative inline-block group"
                        >
                            Contato
                            <span
                                class="absolute -bottom-1 left-0 w-0 h-0.5 bg-[#FDD017] transition-all duration-300 group-hover:w-full"
                            ></span>
                        </a>
                    </li>
                </ul>
            </div>

            <!-- Coluna 3: Contato -->
            <div
                class="flex flex-col footer-col opacity-0 translate-y-8"
            >
                <h4
                    class="text-lg font-black tracking-widest text-[#FDD017] uppercase mb-6"
                >
                    Contato
                </h4>
                <ul class="flex flex-col gap-5">
                    <li class="flex items-start gap-3 group">
                        <Icon
                            name="map-pin"
                            class="w-5 h-5 text-[#FDD017] shrink-0 mt-0.5 opacity-80 group-hover:opacity-100 group-hover:animate-bounce transition-all"
                        />
                        <span
                            class="text-sm font-medium text-[#F8F5ED]/80 leading-relaxed"
                            >Vitória, Espírito Santo<br />Atendimento em
                            todo o estado.</span
                        >
                    </li>
                    <li class="flex items-center gap-3 group">
                        <Icon
                            name="phone"
                            class="w-5 h-5 text-[#FDD017] shrink-0 opacity-80 group-hover:opacity-100 group-hover:animate-pulse transition-all"
                        />
                        <a
                            href="#"
                            class="text-sm font-bold text-[#FDD017] hover:text-[#ffdf4d] transition-colors"
                            >(27) 99999-9999</a
                        >
                    </li>
                    <li class="flex items-center gap-3 group">
                        <Icon
                            name="mail"
                            class="w-5 h-5 text-[#FDD017] shrink-0 opacity-80 group-hover:opacity-100 group-hover:animate-pulse transition-all"
                        />
                        <a
                            href="mailto:contato@evolutionmanutencoes.com.br"
                            class="text-sm font-medium text-[#F8F5ED]/80 hover:text-[#FDD017] transition-colors"
                            >contato@evolutionmanutencoes.com.br</a
                        >
                    </li>
                </ul>
            </div>
        </div>

        <!-- Direitos Autorais e Políticas -->
        <div
            class="border-t border-white/10 pt-8 mt-8 flex flex-col md:flex-row items-center justify-between gap-4 footer-bottom opacity-0"
        >
            <p class="text-xs font-medium text-[#F8F5ED]/50">
                &copy; 2026 Evolution Manutenção. Todos os direitos
                reservados.
            </p>
            <div class="flex gap-6">
                <a
                    href="#"
                    class="text-xs font-bold text-[#F8F5ED]/50 hover:text-[#FDD017] transition-colors relative inline-block group"
                >
                    Política de Privacidade
                    <span
                        class="absolute -bottom-1 left-0 w-0 h-[1px] bg-[#FDD017] transition-all duration-300 group-hover:w-full"
                    ></span>
                </a>
                <a
                    href="#"
                    class="text-xs font-bold text-[#F8F5ED]/50 hover:text-[#FDD017] transition-colors relative inline-block group"
                >
                    Termos de Uso
                    <span
                        class="absolute -bottom-1 left-0 w-0 h-[1px] bg-[#FDD017] transition-all duration-300 group-hover:w-full"
                    ></span>
                </a>
            </div>
        </div>
    </div>
</footer>

<!-- BACK TO TOP BUTTON -->
<button
    id="back-to-top"
    class="fixed bottom-6 right-6 md:bottom-10 md:right-10 z-[60] w-10 h-10 md:w-12 md:h-12 bg-black/40 backdrop-blur-md border border-[#FDD017]/40 rounded-full flex items-center justify-center opacity-0 pointer-events-none translate-y-8 transition-all duration-500 hover:bg-[#FDD017]/10 hover:border-[#FDD017]/80 group shadow-lg"
    aria-label="Voltar ao topo"
>
    <Icon
        name="chevron-up"
        class="w-5 h-5 text-[#FDD017] group-hover:-translate-y-0.5 transition-all duration-300"
    />
</button>

<script>
    // --- BACK TO TOP BUTTON LOGIC ---
    const backToTopBtn = document.getElementById("back-to-top");
    
    if (backToTopBtn) {
        window.addEventListener("scroll", () => {
            if (window.scrollY > 400) {
                backToTopBtn.classList.remove("opacity-0", "pointer-events-none", "translate-y-8");
                backToTopBtn.classList.add("opacity-100", "pointer-events-auto", "translate-y-0");
            } else {
                backToTopBtn.classList.add("opacity-0", "pointer-events-none", "translate-y-8");
                backToTopBtn.classList.remove("opacity-100", "pointer-events-auto", "translate-y-0");
            }
        }, { passive: true });

        backToTopBtn.addEventListener("click", () => {
            window.scrollTo({
                top: 0,
                behavior: "smooth",
            });
        });
    }
</script>
