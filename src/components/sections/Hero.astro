---
// Hero.astro — Reconstruído fiel ao commit b6286164 (pré-Astro)
const baseUrl = import.meta.env.BASE_URL;
---
<!-- HERO SECTION WRAPPER — engloba Nav + Conteúdo -->
<header class="relative w-full min-h-[100dvh] flex flex-col overflow-hidden">

    <!-- 1. CINEMATIC BACKGROUND — position:absolute relativo ao <header> (não ao body) -->
    <div class="video-wrapper" id="video-bg">
        <video autoplay loop muted playsinline fetchpriority="low">
            <source
                src="https://assets.mixkit.co/videos/preview/mixkit-solar-panels-in-a-field-under-the-sun-43343-large.mp4"
                type="video/mp4"
            />
        </video>
        <div class="vignette-overlay"></div>
    </div>

    <!-- 2. DS ENERGY BEAMS — contido no <header>, não vaza para outras seções -->
    <div class="ds-grid flex">
        <div class="ds-col">
            <div class="beam h-[200px]" style="animation-duration: 5s; animation-delay: 1s;"></div>
        </div>
        <div class="ds-col">
            <div class="beam h-[150px]" style="animation-duration: 4s; animation-delay: 0s;"></div>
        </div>
        <div class="ds-col">
            <div class="beam h-[250px]" style="animation-duration: 5.5s; animation-delay: 1.5s;"></div>
        </div>
        <div class="ds-col">
            <div class="beam h-[120px]" style="animation-duration: 3.5s; animation-delay: 2.5s;"></div>
        </div>
        <div class="ds-col">
            <div class="beam h-[180px]" style="animation-duration: 4.5s; animation-delay: 0.5s;"></div>
        </div>
        <div class="beam h-[220px]" style="left: auto; right: -1px; animation-duration: 6s; animation-delay: 2s;"></div>
    </div>



    <!-- NAVBAR (inline aqui como no original) -->
    <nav
        class="relative z-50 w-full px-6 md:px-12 py-8 flex justify-between items-center opacity-0"
        id="nav-animate"
    >
        <!-- Brand Logo (Inline SVG — como no original) -->
        <a href={baseUrl} class="relative inline-flex items-center justify-center transform transition-transform hover:scale-105">
            <!-- Círculo branco ao fundo para destacar o raio preto vazado do SVG -->
            <div class="absolute w-[45%] h-[45%] bg-[#F8F5ED] rounded-full z-0"></div>
            <svg viewBox="0 0 300 300" version="1.1" xmlns="http://www.w3.org/2000/svg" xml:space="preserve" style="fill-rule:evenodd;clip-rule:evenodd;stroke-linejoin:round;stroke-miterlimit:2;" class="relative z-10 h-12 md:h-16 lg:h-20 object-contain" aria-label="Evolution Logo" role="img">
                <g id="Fundo">
                    <path d="M129.558,-0l41.717,0c0.164,0.241 -0.223,0.477 0.595,0.872c5.059,2.442 4.7,4.791 8.65,20.572c0.151,0.605 1.574,6.287 1.955,7.547c0.267,0.883 -0.199,0.967 2.629,11.223c0.514,1.863 1.849,0.121 17.231,7.701c2.441,1.203 2.459,-0.095 10.513,-4.531c0.799,-0.44 6.676,-3.676 9.705,-5.975c1.025,-0.778 6.213,-3.661 6.761,-3.965c8.934,-4.964 11.234,-0.583 26.076,14.218c11.358,11.327 16.575,14.467 12.282,22.966c-2.323,4.6 -2.947,4.202 -5.288,8.789c-3.118,6.11 -3.925,5.59 -7.051,11.719c-1.974,3.869 -4.257,3.788 -2.125,8.056c2.766,5.535 2.83,5.458 4.875,11.319c1.633,4.681 2.001,4.782 2.424,4.898c3.322,0.911 35.073,8.133 36.341,9.305c1.595,1.475 1.679,1.353 2.786,3.169c0.627,1.029 0.954,0.582 1.198,0.73l0,42.774c-0.244,0.149 -0.571,-0.299 -1.198,0.73c-1.107,1.816 -1.191,1.694 -2.786,3.169c-1.268,1.172 -33.027,8.396 -36.341,9.305c-1.222,0.335 -3.239,8.194 -5.377,12.493c-2.426,4.877 -3.233,4.979 -2.146,7.092c3.139,6.104 3.915,5.602 7.05,11.719c3.138,6.123 3.923,5.616 7.051,11.719c4.78,9.324 1.7,10.768 -9.94,22.374c-17.404,17.353 -18.551,20.564 -28.204,15.572c-7.159,-3.702 -6.658,-4.453 -13.744,-8.357c-0.641,-0.353 -6.922,-3.814 -7.922,-4.572c-4.291,-3.252 -4.481,0.463 -17.767,4.939c-4.117,1.387 -4.19,1.624 -4.676,3.482c-1.235,4.725 -1.171,4.687 -2.345,9.377c-5.238,20.931 -5.003,25.48 -9.894,28.376c-1.066,0.632 -0.573,0.935 -0.732,1.195l-42.892,0c-0.159,-0.26 0.334,-0.563 -0.732,-1.195c-5.815,-3.444 -5.255,-12.073 -9.292,-25.452c-0.322,-1.068 0.212,-1.164 -3.215,-13.567c-0.407,-1.472 -1.389,-0.26 -17.441,-7.858c-2.167,-1.026 -2.201,-0.012 -9.723,4.092c-7.048,3.845 -18.613,13.27 -24.242,11.499c-3.712,-1.167 -3.551,-1.635 -23.589,-21.617c-6.287,-6.27 -10.593,-9.367 -7.223,-16.046c3.509,-6.953 6.043,-9.826 8.462,-14.546c2.363,-4.612 7.823,-10.044 6.233,-13.327c-3.381,-6.982 -3.422,-6.912 -6.049,-14.249c-1.155,-3.225 -1.514,-3.265 -4.88,-3.854c-0.86,-0.151 -25.325,-6.239 -27.526,-6.787c-4.72,-1.175 -6.369,-1.391 -8.553,-4.975c-0.627,-1.029 -0.955,-0.582 -1.198,-0.73l0,-42.774c0.243,-0.148 0.571,0.299 1.198,-0.73c1.107,-1.816 1.191,-1.694 2.786,-3.169c1.22,-1.128 36.011,-9.217 36.34,-9.307c1.303,-0.357 2.416,-6.482 5.963,-13.665c1.541,-3.12 1.303,-3.348 -0.408,-6.401c-14.863,-26.519 -19.3,-26.636 -15.074,-34.722c1.26,-2.411 1.502,-2.266 23.713,-24.415c8.549,-8.525 13.267,-3.471 18.762,-0.418c0.592,0.329 14.153,8.492 14.689,8.79c0.548,0.305 5.761,3.203 6.763,3.967c2.351,1.793 2.215,-1.274 16.59,-6.114c4.115,-1.386 4.19,-1.622 4.676,-3.482c8.871,-33.925 7.278,-35.394 11.782,-37.505c1.1,-0.515 1.096,-0.484 1.776,-1.444Zm-40.294,156.728c-0.132,-13.945 -0.601,-15.933 4.302,-29.934c2.252,-6.432 11.998,-22.106 26.731,-30.148c23.11,-12.616 52.645,-10.811 74.383,10.971c6.27,6.283 11.753,16.791 12.589,19.178c5.375,15.351 5.033,20.885 3.783,32.263c-1.399,12.735 -10.087,31.165 -26.688,41.828c-19.036,12.227 -33.472,10.626 -43.028,9.582c-15.073,-1.647 -28.413,-11.529 -32.507,-15.474c-12.183,-11.738 -17.249,-23.407 -19.564,-38.265Z" style="fill:#fdbf1c;fill-opacity:1;"/>
                    <path d="M170.418,67.098l-62.976,93.235l33.818,0.287l-16.352,72.283l67.65,-99.139l-34.194,0.492l12.054,-67.158Z"/>
                </g>
            </svg>
        </a>

        <!-- Menu Links (Desktop) -->
        <div class="hidden md:flex gap-8 text-[11px] font-extrabold tracking-[0.2em] text-white/50 uppercase">
            <a href="#" class="hover:text-[#FDD017] transition-colors">Início</a>
            <a href="#diferenciais" class="hover:text-[#FDD017] transition-colors">Diferenciais</a>
            <a href="#servicos" class="hover:text-[#FDD017] transition-colors">Serviços</a>
            <a href="#sobre" class="hover:text-[#FDD017] transition-colors">Sobre Nós</a>
            <a href={`${baseUrl}contato`} class="hover:text-[#FDD017] transition-colors">Contato</a>
        </div>

        <!-- Hamburger Button -->
        <button
            id="mobile-menu-btn"
            aria-label="Abrir menu de navegação"
            class="md:hidden text-[#FDD017] p-2 focus:outline-none hover:scale-110 transition-transform"
        >
            <svg xmlns="http://www.w3.org/2000/svg" class="w-8 h-8" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2">
                <path stroke-linecap="round" stroke-linejoin="round" d="M4 6h16M4 12h16M4 18h16" />
            </svg>
        </button>
    </nav>

    <!-- Mobile Menu Overlay -->
    <div
        id="mobile-menu"
        class="fixed inset-0 bg-[#000000]/60 z-[60] hidden flex-col items-center justify-center backdrop-blur-lg transition-all duration-300 opacity-0 translate-y-[-20px]"
    >
        <button
            id="close-menu-btn"
            aria-label="Fechar menu de navegação"
            class="absolute top-8 right-6 text-[#FDD017] p-2 focus:outline-none hover:scale-110 transition-transform"
        >
            <svg xmlns="http://www.w3.org/2000/svg" class="w-10 h-10" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2">
                <path stroke-linecap="round" stroke-linejoin="round" d="M6 18L18 6M6 6l12 12" />
            </svg>
        </button>
        <div class="flex flex-col items-center gap-10 text-xl font-bold tracking-widest text-[#F8F5ED] uppercase">
            <a href="#" class="mobile-link hover:text-[#FDD017] transition-colors">Início</a>
            <a href="#diferenciais" class="mobile-link hover:text-[#FDD017] transition-colors">Diferenciais</a>
            <a href="#servicos" class="mobile-link hover:text-[#FDD017] transition-colors">Serviços</a>
            <a href="#sobre" class="mobile-link hover:text-[#FDD017] transition-colors">Sobre Nós</a>
            <a href={`${baseUrl}contato`} class="mobile-link hover:text-[#FDD017] transition-colors">Contato</a>
        </div>
    </div>

    <!-- MAIN CONTENT (Centered) -->
    <main class="relative z-10 flex-1 flex flex-col items-center justify-center px-4 sm:px-8 w-full max-w-5xl mx-auto text-center pb-12">

        <!-- Badge -->
        <div
            class="inline-flex items-center gap-2 px-3 py-1.5 rounded-full border border-[#FDD017]/30 bg-[#FDD017]/5 backdrop-blur-sm mb-6 opacity-0"
            id="badge-animate"
        >
            <span class="relative flex h-2 w-2">
                <span class="animate-ping absolute inline-flex h-full w-full rounded-full bg-[#FDD017] opacity-75"></span>
                <span class="relative inline-flex rounded-full h-2 w-2 bg-[#FDD017]"></span>
            </span>
            <span class="text-[10px] font-bold tracking-widest uppercase text-[#FDD017]">A Nova Era da Manutenção</span>
        </div>

        <!-- Headline — span VAZIO para o GSAP TextPlugin escrever -->
        <h1 class="text-[1.75rem] md:text-5xl lg:text-[4rem] font-extrabold leading-tight tracking-tight mb-6 min-h-[120px] md:min-h-[140px] flex items-center justify-center flex-wrap px-2">
            <span id="headline"></span><span class="typewriter-cursor"></span>
        </h1>

        <!-- Subheadline -->
        <p
            class="text-sm sm:text-base md:text-xl font-medium text-white/70 max-w-2xl leading-relaxed mb-10 opacity-0 px-2"
            id="subheadline"
        >
            Especialistas em manutenção que transformam problemas em <span class="text-[#F8F5ED] font-bold relative inline-block">potência<span class="absolute bottom-1 left-0 w-full h-1 bg-[#FDD017]/40 -z-10"></span></span> e tranquilidade.
        </p>

        <!-- CTA -->
        <div class="opacity-0 mb-12" id="cta-animate">
            <a
                class="group isolate inline-flex cursor-pointer overflow-hidden transition-all duration-300 hover:scale-[1.02] hover:shadow-[0_0_40px_10px_rgba(253,208,23,0.35)] bg-gradient-to-b from-[#F8F5ED]/10 via-[#F8F5ED]/0 to-[#F8F5ED]/5 rounded-full relative shadow-[0_0_20px_rgba(253,208,23,0.2),0_4px_30px_rgba(253,208,23,0.1)]"
                href="#contato"
            >
                <!-- Borda Giratória (Spin Animation) -->
                <div class="absolute inset-0 overflow-hidden rounded-full">
                    <div
                        class="absolute inset-[-100%] w-[300%] h-[300%] left-[-100%] top-[-100%] animate-[spin_4s_linear_infinite]"
                        style="background: conic-gradient(from 0deg, transparent 0deg, transparent 80deg, rgba(253,208,23,0.9) 180deg, transparent 280deg, transparent 360deg);"
                    ></div>
                </div>
                <!-- Fundo Escuro Interno -->
                <div class="absolute inset-[1px] rounded-full backdrop-blur-xl z-0 bg-[#000000]/90"></div>

                <!-- Conteúdo Interno -->
                <div class="z-10 flex gap-4 sm:w-auto overflow-hidden w-full rounded-full pt-3 pr-5 pb-3 pl-4 relative items-center">
                    <!-- Ícone Sun -->
                    <div class="relative z-20 w-8 h-8 rounded-full bg-gradient-to-b from-[#FDD017] to-yellow-600 flex items-center justify-center shadow-lg shadow-[#FDD017]/30 ring-1 ring-white/20 group-hover:rotate-180 transition-transform duration-700">
                        <i data-lucide="sun" class="w-4 h-4 text-[#000000] fill-[#000000]"></i>
                    </div>

                    <!-- Texto -->
                    <span class="whitespace-nowrap relative z-10 font-bold tracking-widest text-sm md:text-base text-[#F8F5ED]/95 group-hover:text-[#FDD017] transition-colors uppercase">Falar com Especialista</span>

                    <!-- Seta Direita -->
                    <span class="inline-flex items-center justify-center z-10 bg-white/10 w-7 h-7 rounded-full ml-1 relative group-hover:translate-x-1 group-hover:bg-[#FDD017] group-hover:text-[#000000] transition-all duration-300 text-white/80">
                        <i data-lucide="arrow-right" class="w-3.5 h-3.5"></i>
                    </span>
                </div>
            </a>
        </div>

        <!-- Scroll Indicator -->
        <div
            class="absolute bottom-8 left-1/2 -translate-x-1/2 flex flex-col items-center opacity-0 cursor-pointer hover:scale-110 transition-transform"
            id="scroll-indicator"
            onclick="document.getElementById('diferenciais').scrollIntoView({behavior: 'smooth'})"
        >
            <i data-lucide="chevron-down" class="w-8 h-8 text-[#FDD017] animate-bounce"></i>
        </div>
    </main>
</header>

<style>
    .typewriter-cursor {
        display: inline-block;
        width: 4px;
        height: 0.9em;
        background-color: #fdd017;
        margin-left: 6px;
        animation: blink 0.8s step-end infinite;
        transform: translateY(2px);
        box-shadow: 0 0 8px #fdd017;
    }
    @keyframes blink {
        0%, 100% { opacity: 1; }
        50% { opacity: 0; }
    }
</style>

<script>
    // Mobile Menu Toggle
    const mobileBtn = document.getElementById("mobile-menu-btn");
    const closeBtn = document.getElementById("close-menu-btn");
    const mobileMenu = document.getElementById("mobile-menu");
    const mobileLinks = document.querySelectorAll(".mobile-link");

    function openMenu() {
        if (!mobileMenu) return;
        mobileMenu.classList.remove("hidden");
        mobileMenu.classList.add("flex");
        requestAnimationFrame(() => {
            mobileMenu.classList.remove("opacity-0", "translate-y-[-20px]");
        });
        document.body.style.overflow = "hidden";
    }

    function closeMenu() {
        if (!mobileMenu) return;
        mobileMenu.classList.add("opacity-0", "translate-y-[-20px]");
        setTimeout(() => {
            mobileMenu.classList.add("hidden");
            mobileMenu.classList.remove("flex");
            document.body.style.overflow = "";
        }, 300);
    }

    if (mobileBtn) mobileBtn.addEventListener("click", openMenu);
    if (closeBtn) closeBtn.addEventListener("click", closeMenu);
    mobileLinks.forEach((link) => link.addEventListener("click", closeMenu));

    if (mobileMenu) {
        mobileMenu.addEventListener("click", (e) => {
            if (e.target === mobileMenu) closeMenu();
        });
    }
</script>
