---
import "../styles/global.css";
interface Props {
    title?: string;
    description?: string;
}

const { 
    title = "Evolution Manutenção | O Poder do Sol", 
    description = "Especialistas em manutenção preventiva, corretiva e limpeza técnica de usinas solares. Blindagem e inteligência técnica para maximizar o retorno do seu investimento."
} = Astro.props;
---

<!DOCTYPE html>
<html lang="pt-BR" class="scroll-smooth">
    <head>
        <meta charset="utf-8" />
        <meta content="width=device-width, initial-scale=1.0" name="viewport" />
        <meta name="description" content={description} />
        <title>{title}</title>
        <link
            rel="icon"
            type="image/svg+xml"
            href="/evolution_manutencoes/raw_file/LOGOBRUTOsvg.svg"
        />
        <link
            rel="shortcut icon"
            href="/evolution_manutencoes/raw_file/LOGOBRUTOsvg.svg"
        />
        
        <!-- Preconnects -->
        <link
            rel="preconnect"
            href="https://cdnjs.cloudflare.com"
            crossorigin
        />

        <!-- Preloads for Critical Scripts and LCP -->
        <link
            rel="preload"
            href="https://cdnjs.cloudflare.com/ajax/libs/gsap/3.12.2/gsap.min.js"
            as="script"
        />

        <!-- Google Fonts -->
        <link rel="preconnect" href="https://fonts.googleapis.com" />
        <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin />
        <link
            href="https://fonts.googleapis.com/css2?family=Montserrat:wght@300;400;600;800;900&display=swap"
            rel="preload"
            as="style"
            onload="this.onload=null;this.rel='stylesheet'"
        />
        <noscript>
            <link
                rel="stylesheet"
                href="https://fonts.googleapis.com/css2?family=Montserrat:wght@300;400;600;800;900&display=swap"
            />
        </noscript>

        <!-- GSAP for animations -->
        <script
            defer
            src="https://cdnjs.cloudflare.com/ajax/libs/gsap/3.12.2/gsap.min.js"
        ></script>
        <script
            defer
            src="https://cdnjs.cloudflare.com/ajax/libs/gsap/3.12.2/TextPlugin.min.js"
        ></script>
        <script
            defer
            src="https://cdnjs.cloudflare.com/ajax/libs/gsap/3.12.2/ScrollTrigger.min.js"
        ></script>

        <style is:global>
            body {
                background-color: #000000;
                color: #f8f5ed;
                overflow-x: hidden;
                min-height: 100vh;
            }

            /* --- BACKGROUND CINEMÁTICO --- */
            .video-wrapper {
                position: absolute;
                inset: 0;
                z-index: 0;
                overflow: hidden;
                height: 100%;
            }
            .video-wrapper video {
                width: 100%;
                height: 100%;
                object-fit: cover;
                transform: scale(1.05); /* Leve scale para permitir zoom out sutil */
                opacity: 0.5;
                filter: grayscale(30%) contrast(120%);
            }
            /* Máscara radial - Menor e mais centralizada */
            .vignette-overlay {
                position: absolute;
                inset: 0;
                background: radial-gradient(
                    ellipse at center,
                    transparent 0%,
                    rgba(0, 0, 0, 0.85) 90%
                );
                z-index: 1;
            }

            /* --- LUZ SOLAR ANIMADA (MOUSE FOLLOWER) --- */
            .solar-glow-wrapper {
                position: fixed;
                top: 0;
                left: 0;
                width: 80vw;
                height: 80vw;
                max-width: 900px;
                max-height: 900px;
                z-index: 2;
                pointer-events: none;
                mix-blend-mode: screen;
            }
            .solar-glow {
                width: 100%;
                height: 100%;
                background: radial-gradient(
                    circle,
                    rgba(253, 208, 23, 0.55) 0%,
                    rgba(253, 208, 23, 0.25) 35%,
                    rgba(253, 208, 23, 0) 70%
                );
                border-radius: 50%;
                animation: breathe 5s ease-in-out infinite alternate;
                filter: blur(60px);
            }
            @keyframes breathe {
                0% {
                    transform: scale(0.85);
                    opacity: 0.7;
                }
                100% {
                    transform: scale(1.2);
                    opacity: 1;
                }
            }

            /* --- DS BEAM GRID --- */
            .ds-grid {
                position: absolute;
                inset: 0;
                z-index: 3;
                pointer-events: none;
                display: flex;
                width: 100%;
                max-width: 90rem;
                margin: 0 auto;
                opacity: 0.45; /* Contraste aumentado */
                border-right: 1px solid rgba(253, 208, 23, 0.5); /* Borda mais visível */
            }
            .ds-col {
                flex: 1;
                border-left: 1px solid rgba(253, 208, 23, 0.5);
                position: relative;
            }
            @keyframes beam-fall {
                0% {
                    transform: translateY(-100%);
                    opacity: 0;
                }
                10% {
                    opacity: 1;
                }
                90% {
                    opacity: 1;
                }
                100% {
                    transform: translateY(100vh);
                    opacity: 0;
                }
            }
            .beam {
                position: absolute;
                top: 0;
                left: -1px;
                width: 2px;
                background: linear-gradient(
                    to bottom,
                    transparent,
                    #fdd017,
                    #ffffff,
                    #fdd017,
                    transparent
                );
                box-shadow: 0 0 15px #fdd017;
                animation: beam-fall 4s linear infinite;
            }
        </style>

        <!-- Google Tag Manager (Lazy Load Otimizado para Lighthouse) -->
        <script is:inline>
            const loadGTM = () => {
                if (window.gtmLoaded) return;
                window.gtmLoaded = true;
                (function (w, d, s, l, i) {
                    w[l] = w[l] || [];
                    w[l].push({
                        "gtm.start": new Date().getTime(),
                        event: "gtm.js",
                    });
                    var f = d.getElementsByTagName(s)[0],
                        j = d.createElement(s),
                        dl = l != "dataLayer" ? "&l=" + l : "";
                    j.async = true;
                    j.src =
                        "https://www.googletagmanager.com/gtm.js?id=" + i + dl;
                    f.parentNode.insertBefore(j, f);
                })(window, document, "script", "dataLayer", "GTM-KS96GQS9");
            };
            ["scroll", "mousemove", "touchstart", "click"].forEach((e) =>
                window.addEventListener(e, loadGTM, { once: true })
            );
            setTimeout(loadGTM, 3500);
        </script>
    </head>
    <body class="relative flex flex-col justify-between">
        <!-- Google Tag Manager (noscript) -->
        <noscript>
            <iframe
                src="https://www.googletagmanager.com/ns.html?id=GTM-KS96GQS9"
                height="0"
                width="0"
                style="display:none;visibility:hidden"></iframe>
        </noscript>

        <!-- 1. CINEMATIC BACKGROUND -->
        <div class="video-wrapper" id="video-bg">
            <video autoplay loop muted playsinline fetchpriority="low">
                <source
                    src="https://assets.mixkit.co/videos/preview/mixkit-solar-panels-in-a-field-under-the-sun-43343-large.mp4"
                    type="video/mp4"
                />
            </video>
            <div class="vignette-overlay"></div>
        </div>

        <!-- 2. SOLAR GLOW (Mouse Follower) -->
        <div class="solar-glow-wrapper">
            <div class="solar-glow"></div>
        </div>

        <!-- 3. DS ENERGY BEAMS -->
        <div class="ds-grid flex">
            <div class="ds-col">
                <div
                    class="beam h-[200px]"
                    style="animation-duration: 5s; animation-delay: 1s;"
                >
                </div>
            </div>
            <div class="ds-col">
                <div
                    class="beam h-[150px]"
                    style="animation-duration: 4s; animation-delay: 0s;"
                >
                </div>
            </div>
            <div class="ds-col">
                <div
                    class="beam h-[250px]"
                    style="animation-duration: 5.5s; animation-delay: 1.5s;"
                >
                </div>
            </div>
            <div class="ds-col">
                <div
                    class="beam h-[120px]"
                    style="animation-duration: 3.5s; animation-delay: 2.5s;"
                >
                </div>
            </div>
            <div class="ds-col">
                <div
                    class="beam h-[180px]"
                    style="animation-duration: 4.5s; animation-delay: 0.5s;"
                >
                </div>
            </div>
            <div
                class="beam h-[220px]"
                style="left: auto; right: -1px; animation-duration: 6s; animation-delay: 2s;"
            >
            </div>
        </div>

        <slot />
    </body>
</html>
