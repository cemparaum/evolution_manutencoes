---
import Layout from "../layouts/Layout.astro";
import Header from "../components/sections/Header.astro";
import Footer from "../components/sections/Footer.astro";
import Icon from "../components/Icon.astro";

const baseUrl = import.meta.env.BASE_URL;

const schema = JSON.stringify({
  "@context": "https://schema.org",
  "@type": "Service",
  "name": "Manutenção Preventiva de Energia Solar",
  "description": "Inspeções termográficas e análises profundas que localizam microfissuras e falhas invisíveis a olho nu, garantindo 100% de performance contínua para sua usina solar.",
  "provider": {
    "@type": "LocalBusiness",
    "name": "Evolution Manutenção",
    "image": "https://evolutionmanutencoes.com.br/evolution_manutencoes/raw_file/LOGOBRUTOsvg.svg",
    "url": "https://evolutionmanutencoes.com.br"
  },
  "areaServed": "BR",
  "hasOfferCatalog": {
    "@type": "OfferCatalog",
    "name": "Serviços de Manutenção Preventiva Solar",
    "itemListElement": [
      {
        "@type": "Offer",
        "itemOffered": {
          "@type": "Service",
          "name": "Análise Termográfica"
        }
      },
      {
        "@type": "Offer",
        "itemOffered": {
          "@type": "Service",
          "name": "Inspeção Elétrica"
        }
      },
      {
        "@type": "Offer",
        "itemOffered": {
          "@type": "Service",
          "name": "Emissão de Laudo de Performance"
        }
      }
    ]
  }
});
---

<Layout 
    title="Manutenção Preventiva | Evolution Manutenção "
    description="Inspeções termográficas e análises profundas para garantir 100% de performance contínua da sua usina solar, prevenindo falhas antes que ocorram."
    schema={schema}
>
    <Header />
    
    <main class="relative pt-28 md:pt-32 pb-20 overflow-hidden selection:bg-[#FDD017]/30">
        <!-- Main Background Image with Overlay from DS -->
        <div class="fixed z-0 top-0 right-0 bottom-0 left-0 pointer-events-none">
            <div class="absolute inset-0 bg-gradient-to-b from-[#050505]/90 via-[#050505]/60 to-[#050505]"></div>
            <div class="absolute inset-0 bg-[radial-gradient(ellipse_at_center,_var(--tw-gradient-stops))] from-[#FDD017]/10 via-[#050505]/0 to-[#050505]/0"></div>
        </div>

        <!-- Vertical Grid Lines with Falling Beams from DS -->
        <div class="fixed inset-0 z-0 pointer-events-none flex w-full max-w-7xl mx-auto border-r border-white/5 opacity-60">
            <div class="flex-1 border-l border-white/5 h-full relative overflow-hidden">
                <span class="absolute bottom-8 left-4 text-white/10 text-xs font-mono">01</span>
            </div>
            <div class="flex-1 border-l border-white/5 h-full relative overflow-hidden">
                <div class="absolute top-0 -left-[1px] w-[1px] h-64 bg-gradient-to-b from-transparent via-[#FDD017]/60 to-transparent animate-beam-1"></div>
                <span class="absolute bottom-8 left-4 text-white/10 text-xs font-mono">02</span>
            </div>
            <div class="flex-1 border-l border-white/5 h-full flex justify-center relative overflow-hidden">
                <div class="absolute top-0 -left-[1px] w-[1px] h-96 bg-gradient-to-b from-transparent via-[#FDD017]/80 to-transparent animate-beam-2"></div>
                <div class="h-full border-r border-dashed border-[#FDD017]/20 w-px"></div>
                <div class="absolute top-0 left-1/2 -translate-x-1/2 w-[1px] h-64 bg-gradient-to-b from-transparent via-[#FDD017] to-transparent animate-beam-1" style="animation-delay: 1.5s;"></div>
                <span class="absolute bottom-8 text-[#FDD017]/30 text-xs font-mono">03</span>
            </div>
            <div class="flex-1 border-l border-white/5 h-full relative overflow-hidden">
                <div class="absolute top-0 -left-[1px] w-[1px] h-48 bg-gradient-to-b from-transparent via-[#FDD017]/60 to-transparent animate-beam-3"></div>
                <span class="absolute bottom-8 left-4 text-white/10 text-xs font-mono">04</span>
            </div>
            <div class="flex-1 border-l border-white/5 h-full relative overflow-hidden">
                <span class="absolute bottom-8 left-4 text-white/10 text-xs font-mono">05</span>
            </div>
        </div>

        <div class="flex-1 flex flex-col w-full max-w-7xl mr-auto ml-auto relative z-10">
            
            <!-- HERO SECTION (from DS) -->
            <section id="hero" class="flex-1 grid grid-cols-1 lg:grid-cols-12 pt-8 md:pt-20 pb-10 gap-x-4 gap-y-4 items-center min-h-[70vh] lg:min-h-[80vh]">
                <!-- Left: Title & Description -->
                <div class="col-span-1 lg:col-span-6 px-6 md:px-10 pt-8 lg:pt-0 flex flex-col justify-center">
                    <div class="inline-flex items-center gap-2 text-[#FDD017] mb-8 animate-on-scroll">
                        <span class="flex h-2 w-2 rounded-full bg-[#FDD017]"></span>
                        <span class="text-xs font-bold tracking-widest uppercase text-[#FDD017]/80">INSPEÇÃO & BLINDAGEM</span>
                    </div>
                                        <h1 class="text-4xl md:text-5xl lg:text-[4.5rem] leading-[0.9] tracking-tighter text-white font-medium mb-6 animate-on-scroll" style="animation-delay: 0.1s;">
                        Manutenção Preventiva<br />
                        <span class="text-transparent bg-clip-text bg-gradient-to-r from-[#FDD017] via-yellow-500 to-yellow-600">de Energia Solar.</span>
                    </h1>
                    <p class="leading-relaxed text-lg font-medium text-white/60 max-w-lg animate-on-scroll" style="animation-delay: 0.2s;">
                        Inspeções termográficas e análises profundas que localizam microfissuras e falhas invisíveis a olho nu, garantindo 100% de performance contínua para sua usina solar.
                    </p>
                    
                    <div class="mt-8 flex flex-col sm:flex-row gap-4 items-stretch sm:items-center animate-on-scroll" style="animation-delay: 0.3s;">
                        <!-- DS Primary Button (Particle) -->
                        <a href="#detalhes" class="button-custom w-full sm:w-auto text-center justify-center" type="button">
                            <div class="points_wrapper">
                                <i class="point"></i><i class="point"></i><i class="point"></i><i class="point"></i><i class="point"></i><i class="point"></i><i class="point"></i>
                            </div>
                            <span class="inner justify-center">
                                Entender o Processo
                                <Icon name="arrow-right" class="icon" />
                            </span>
                        </a>

                        <!-- DS Glass Button -->
                        <a class="group isolate inline-flex cursor-pointer overflow-hidden transition-all duration-300 hover:scale-105 hover:shadow-[0_0_50px_10px_rgba(253,208,23,0.45)] bg-gradient-to-b from-white/20 via-white/0 to-white/5 rounded-full relative shadow-[0_0_25px_rgba(253,208,23,0.3),0_8px_40px_rgba(253,208,23,0.15)] w-full sm:w-auto justify-center" href={`${baseUrl}contato`}>
                            <div class="absolute inset-0 overflow-hidden rounded-full">
                                <div class="absolute inset-[-100%] w-[300%] h-[300%] left-[-100%] top-[-100%] animate-[spin_3s_linear_infinite]" style="background: conic-gradient(from 0deg, transparent 0deg, transparent 80deg, rgba(253, 208, 23, 0.8) 180deg, transparent 280deg, transparent 360deg);"></div>
                            </div>
                            <div class="absolute inset-[1px] rounded-full backdrop-blur-xl z-0 bg-neutral-950/90"></div>
                            <div class="z-10 flex gap-3 sm:w-auto overflow-hidden text-sm font-medium text-white w-full rounded-full pt-3 pr-5 pb-3 pl-4 relative items-center justify-center">
                                <div class="relative z-20 w-7 h-7 rounded-full bg-gradient-to-b from-[#FDD017] to-yellow-600 flex items-center justify-center shadow-lg shadow-[#FDD017]/30 ring-1 ring-white/20 group-hover:scale-110 transition-transform duration-300 shrink-0">
                                    <Icon name="message-square" class="w-3.5 h-3.5 text-white" />
                                </div>
                                <span class="whitespace-nowrap relative z-10 font-medium tracking-tight text-base text-white/95 group-hover:text-white transition-colors">Falar com Especialista</span>
                            </div>
                        </a>
                    </div>
                </div>

                <!-- Right: Preview Stack -->
                <div class="hidden lg:flex lg:col-span-6 md:pr-10 flex-col lg:pt-20 h-full items-end justify-center">
                    <div class="relative mb-12 mr-4 w-64 md:w-72 md:h-80 aspect-[3/4] group perspective-1000 animate-on-scroll" style="animation-delay: 0.4s;">
                        <div class="absolute -inset-8 bg-[#FDD017]/20 blur-3xl -z-10 opacity-50 group-hover:opacity-70 transition-opacity duration-700"></div>
                        <div class="relative w-full h-full">
                            <div class="card-stack-item absolute inset-0 rounded-lg overflow-hidden border border-white/10 shadow-2xl origin-bottom bg-neutral-900" style="transform: translateY(24px) scale(0.9); z-index: 10; opacity: 0.4;">
                                <div class="w-full h-full bg-gradient-to-br from-[#FDD017]/10 to-black"></div>
                            </div>
                            <div class="card-stack-item absolute inset-0 rounded-lg overflow-hidden border border-white/10 shadow-2xl origin-bottom bg-neutral-900" style="transform: translateY(12px) scale(0.95); z-index: 20; opacity: 0.6;">
                                <div class="w-full h-full bg-gradient-to-br from-[#FDD017]/10 to-black"></div>
                            </div>
                            <div class="card-stack-item absolute inset-0 rounded-lg overflow-hidden border border-white/10 shadow-2xl origin-bottom bg-neutral-900 flex items-center justify-center" style="transform: translateY(0px) scale(1); z-index: 30; opacity: 1;">
                                <div class="absolute inset-0 bg-gradient-to-br from-neutral-800 to-black"></div>
                                <div class="relative z-10 flex flex-col items-center">
                                    <Icon name="shield-check" class="w-24 h-24 text-[#FDD017] mb-4 animate-pulse" />
                                    <div class="text-xl font-bold text-white text-center">Blindagem<br/>Total</div>
                                </div>
                            </div>
                        </div>
                    </div>
                </div>
            </section>

            <!-- DETAILS SECTION using DS Layout & Typography -->
            <section id="detalhes" class="w-full px-6 md:px-10 py-24 border-t border-white/5">
                <div class="mb-16">
                    <h2 class="text-5xl md:text-6xl font-medium tracking-tighter text-white mb-4 animate-on-scroll">Benefícios da Manutenção</h2>
                    <p class="text-lg text-neutral-400 max-w-2xl animate-on-scroll">Proteja seu investimento e garanta a máxima eficiência energética do seu sistema solar com nossa manutenção especializada.</p>
                </div>
                
                <div class="grid grid-cols-1 md:grid-cols-2 gap-6 animate-on-scroll">
                    <!-- DS Card Component 1 -->
                    <div class="flex flex-col min-h-[180px] transition-transform hover:-translate-y-1 duration-300 text-black bg-gradient-to-b from-[#FDD017] to-yellow-600 rounded-xl pt-8 pr-8 pb-8 pl-8 relative shadow-2xl justify-between" style="position: relative; --border-gradient: linear-gradient(180deg, rgba(255, 255, 255, 0.3), rgba(255, 255, 255, 0)); --border-radius-before: 12px">
                        <div>
                            <Icon name="trending-up" class="w-8 h-8 mb-4 text-black" />
                            <h3 class="text-2xl font-bold leading-snug tracking-tight mb-2">Máxima Performance</h3>
                            <p class="text-black/80 font-medium text-sm">Sistemas limpos e inspecionados podem gerar até 30% mais energia do que sistemas sem manutenção regular.</p>
                        </div>
                    </div>

                    <!-- DS Standard Glass Card -->
                    <div class="flex flex-col min-h-[180px] bg-white/5 rounded-lg border border-white/10 backdrop-blur-md p-8 hover:bg-white/10 transition-colors">
                        <Icon name="search" class="w-8 h-8 mb-4 text-[#FDD017]" />
                        <h3 class="text-xl font-semibold text-white mb-2">Prevenção de Falhas</h3>
                        <p class="text-sm text-neutral-400">Inspeção termográfica avançada para detectar microfissuras e hot spots antes que causem danos permanentes aos módulos.</p>
                    </div>

                    <!-- DS Standard Glass Card -->
                    <div class="flex flex-col min-h-[180px] bg-white/5 rounded-lg border border-white/10 backdrop-blur-md p-8 hover:bg-white/10 transition-colors">
                        <Icon name="shield" class="w-8 h-8 mb-4 text-[#FDD017]" />
                        <h3 class="text-xl font-semibold text-white mb-2">Garantia Assegurada</h3>
                        <p class="text-sm text-neutral-400">Mantenha a garantia dos fabricantes válida através de laudos técnicos periódicos e manutenções documentadas.</p>
                    </div>
                    
                    <!-- DS Standard Glass Card -->
                    <div class="flex flex-col min-h-[180px] bg-white/5 rounded-lg border border-white/10 backdrop-blur-md p-8 hover:bg-white/10 transition-colors">
                        <Icon name="zap" class="w-8 h-8 mb-4 text-[#FDD017]" />
                        <h3 class="text-xl font-semibold text-white mb-2">Vida Útil Prolongada</h3>
                        <p class="text-sm text-neutral-400">Cuidados especializados que previnem oxidação, desgaste prematuro e garantem que sua usina dure décadas.</p>
                    </div>
                </div>
            </section>

            <!-- PROCESS SECTION using DS Step Items -->
            <section class="w-full px-6 md:px-10 py-24 border-t border-white/5">
                <div class="grid grid-cols-1 lg:grid-cols-2 gap-16">
                    <div class="animate-on-scroll">
                        <div class="text-xs font-bold tracking-widest uppercase text-[#FDD017] mb-2">Metodologia</div>
                        <h2 class="text-5xl md:text-6xl font-medium tracking-tighter text-white mb-6">Nosso Processo</h2>
                        <p class="text-lg text-neutral-400 mb-8">Etapas rigorosas para garantir o melhor resultado e evitar prejuízos invisíveis.</p>
                        
                        <!-- DS Step Items -->
                        <div class="flex flex-col gap-4" id="steps-container">
                            <div 
                                class="step-item flex cursor-pointer transition-all duration-300 bg-white/5 rounded-lg p-4 shadow-xl backdrop-blur-md gap-x-4 items-center border border-white/10 relative z-10 translate-x-[-10px] group"
                                data-step="0"
                            >
                                <div class="w-8 h-8 shrink-0 rounded-full flex items-center justify-center text-xs font-bold transition-all bg-[#FDD017] text-black shadow-lg shadow-[#FDD017]/20 border-transparent">
                                    01
                                </div>
                                <div>
                                    <h4 class="text-base font-medium text-white">Análise Termográfica</h4>
                                    <p class="text-xs text-neutral-400 mt-1">Mapeamento com drone térmico para identificar hotspots.</p>
                                </div>
                                <Icon 
                                    name="scan-line" 
                                    class="w-5 h-5 ml-auto shrink-0 transition-colors text-[#FDD017]" 
                                />
                            </div>

                            <div 
                                class="step-item flex cursor-pointer transition-all duration-300 bg-white/5 rounded-lg p-4 shadow-xl backdrop-blur-md gap-x-4 items-center border border-white/5 hover:border-[#FDD017]/30 hover:translate-x-[-5px] group"
                                data-step="1"
                            >
                                <div class="w-8 h-8 shrink-0 rounded-full flex items-center justify-center text-xs font-bold transition-all bg-transparent border border-white/20 text-neutral-400 group-hover:text-yellow-400 group-hover:border-yellow-400">
                                    02
                                </div>
                                <div>
                                    <h4 class="text-base font-medium text-white">Inspeção Elétrica</h4>
                                    <p class="text-xs text-neutral-400 mt-1">Reaperto de conexões, medição de string box e inversores.</p>
                                </div>
                                <Icon 
                                    name="zap" 
                                    class="w-5 h-5 ml-auto shrink-0 transition-colors text-neutral-600 group-hover:text-white" 
                                />
                            </div>

                            <div 
                                class="step-item flex cursor-pointer transition-all duration-300 bg-white/5 rounded-lg p-4 shadow-xl backdrop-blur-md gap-x-4 items-center border border-white/5 hover:border-[#FDD017]/30 hover:translate-x-[-5px] group"
                                data-step="2"
                            >
                                <div class="w-8 h-8 shrink-0 rounded-full flex items-center justify-center text-xs font-bold transition-all bg-transparent border border-white/20 text-neutral-400 group-hover:text-yellow-400 group-hover:border-yellow-400">
                                    03
                                </div>
                                <div>
                                    <h4 class="text-base font-medium text-white">Limpeza Técnica Avançada</h4>
                                    <p class="text-xs text-neutral-400 mt-1">Tratamento dos módulos com produtos adequados e sem risco.</p>
                                </div>
                                <Icon 
                                    name="droplets" 
                                    class="w-5 h-5 ml-auto shrink-0 transition-colors text-neutral-600 group-hover:text-white" 
                                />
                            </div>

                            <div 
                                class="step-item flex cursor-pointer transition-all duration-300 bg-white/5 rounded-lg p-4 shadow-xl backdrop-blur-md gap-x-4 items-center border border-white/5 hover:border-[#FDD017]/30 hover:translate-x-[-5px] group"
                                data-step="3"
                            >
                                <div class="w-8 h-8 shrink-0 rounded-full flex items-center justify-center text-xs font-bold transition-all bg-transparent border border-white/20 text-neutral-400 group-hover:text-yellow-400 group-hover:border-yellow-400">
                                    04
                                </div>
                                <div>
                                    <h4 class="text-base font-medium text-white">Emissão de Laudo</h4>
                                    <p class="text-xs text-neutral-400 mt-1">Documentação completa com atestado da saúde da usina.</p>
                                </div>
                                <Icon 
                                    name="file-check" 
                                    class="w-5 h-5 ml-auto shrink-0 transition-colors text-neutral-600 group-hover:text-white" 
                                />
                            </div>
                        </div>
                    </div>
                    
                    <div class="bg-white/5 rounded-xl border border-white/10 p-8 flex flex-col justify-center items-center text-center animate-on-scroll" id="details-card">
                         <div class="w-24 h-24 bg-[#FDD017]/10 rounded-full flex items-center justify-center mb-6 border border-[#FDD017]/20 relative group">
                             <div class="absolute inset-0 bg-[#FDD017]/20 blur-xl rounded-full group-hover:bg-[#FDD017]/40 transition-colors"></div>
                             <div id="icon-0" class="step-detail-icon"><Icon name="scan-line" class="w-10 h-10 text-[#FDD017] relative z-10" /></div>
                             <div id="icon-1" class="step-detail-icon hidden"><Icon name="zap" class="w-10 h-10 text-[#FDD017] relative z-10" /></div>
                             <div id="icon-2" class="step-detail-icon hidden"><Icon name="droplets" class="w-10 h-10 text-[#FDD017] relative z-10" /></div>
                             <div id="icon-3" class="step-detail-icon hidden"><Icon name="file-check" class="w-10 h-10 text-[#FDD017] relative z-10" /></div>
                         </div>
                         <h3 class="text-3xl font-bold text-white mb-4" id="details-title">Análise Termográfica</h3>
                         <p class="text-neutral-400 mb-8 max-w-sm" id="details-desc">Mapeamento aéreo e terrestre detalhado com câmeras térmicas de alta resolução para identificar pontos quentes (hotspots), rachaduras ocultas e falhas de conexão que prejudicam a geração.</p>
                         <a href={`${baseUrl}contato`} class="button-custom w-full max-w-xs">
                             <div class="points_wrapper">
                                <i class="point"></i><i class="point"></i><i class="point"></i><i class="point"></i><i class="point"></i><i class="point"></i>
                            </div>
                            <span class="inner">Solicitar Orçamento</span>
                         </a>
                    </div>
                </div>
            </section>
        </div>
    </main>

    <Footer />
</Layout>

<style>
    /* Gradient Button Animation from DS */
    .button-custom {
        cursor: pointer;
        position: relative;
        display: inline-flex;
        align-items: center;
        justify-content: center;
        overflow: hidden;
        transition: all 0.25s ease;
        background: radial-gradient(65.28% 65.28% at 50% 100%, rgba(253, 208, 23, 0.8) 0%, rgba(253, 208, 23, 0) 100%), linear-gradient(0deg, #FDD017, #FDD017);
        border-radius: 9999px;
        border: none;
        padding: 12px 28px;
        min-height: 48px;
        text-decoration: none;
    }
    .button-custom::before {
        content: "";
        position: absolute;
        inset: 1px;
        background: linear-gradient(177.95deg, rgba(255, 255, 255, 0.3) 0%, rgba(255, 255, 255, 0) 100%);
        border-radius: 9999px;
        transition: all 0.5s ease-in-out;
        z-index: 0;
    }
    .button-custom::after {
        content: "";
        position: absolute;
        inset: 2px;
        background: radial-gradient(65.28% 65.28% at 50% 100%, rgba(253, 208, 23, 0.8) 0%, rgba(253, 208, 23, 0) 100%), linear-gradient(0deg, #FDD017, #FDD017);
        border-radius: 9999px;
        transition: all 0.5s ease-in-out;
        z-index: 0;
    }
    .button-custom:hover .inner :global(svg.icon) { transform: translateX(4px); }
    .inner { z-index: 2; gap: 8px; position: relative; width: 100%; color: #000000; display: inline-flex; align-items: center; justify-content: center; font-size: 0.95rem; font-weight: 600; }
    .inner :global(svg.icon) { width: 18px; height: 18px; transition: transform 0.3s ease; stroke: #000000; fill: none; }
    
    /* Particle Animation inside Button */
    .points_wrapper { overflow: hidden; width: 100%; height: 100%; pointer-events: none; position: absolute; z-index: 1; left: 0; top: 0; }
    .points_wrapper .point { bottom: -10px; position: absolute; animation: floating-points infinite ease-in-out; pointer-events: none; width: 2px; height: 2px; background-color: #fff; border-radius: 9999px; }
    @keyframes floating-points { 0% { transform: translateY(0); } 85% { opacity: 0; } 100% { transform: translateY(-55px); opacity: 0; } }
    .points_wrapper .point:nth-child(1) { left: 10%; opacity: 1; animation-duration: 2.35s; animation-delay: 0.2s; }
    .points_wrapper .point:nth-child(2) { left: 30%; opacity: 0.7; animation-duration: 2.5s; animation-delay: 0.5s; }
    .points_wrapper .point:nth-child(3) { left: 25%; opacity: 0.8; animation-duration: 2.2s; animation-delay: 0.1s; }
    .points_wrapper .point:nth-child(4) { left: 44%; opacity: 0.6; animation-duration: 2.05s; }
    .points_wrapper .point:nth-child(5) { left: 50%; opacity: 1; animation-duration: 1.9s; }
    .points_wrapper .point:nth-child(6) { left: 75%; opacity: 0.5; animation-duration: 1.5s; animation-delay: 1.5s; }
    .points_wrapper .point:nth-child(7) { left: 88%; opacity: 0.9; animation-duration: 2.2s; animation-delay: 0.2s; }

    /* Falling Beams Animation */
    @keyframes beam-fall {
        0% { transform: translateY(-100%); opacity: 0; }
        5% { opacity: 0.5; }
        50% { opacity: 1; }
        95% { opacity: 0.5; }
        100% { transform: translateY(120vh); opacity: 0; }
    }
    .animate-beam-1 { animation: beam-fall 6s linear infinite; animation-delay: 0s; }
    .animate-beam-2 { animation: beam-fall 8s linear infinite; animation-delay: 2s; }
    .animate-beam-3 { animation: beam-fall 7s linear infinite; animation-delay: 4s; }

    /* Scroll animations */
    @keyframes fadeSlideIn { 
        0% { opacity: 0; transform: translateY(30px); filter: blur(8px); } 
        100% { opacity: 1; transform: translateY(0); filter: blur(0px); } 
    } 
    .animate-on-scroll { opacity: 0; }
    .animate-on-scroll.animate { animation: fadeSlideIn 1s cubic-bezier(0.2,0.8,0.2,1) forwards; }
    
    .perspective-1000 {
        perspective: 1000px;
    }
    .card-stack-item {
        transition: transform 0.6s cubic-bezier(0.34, 1.56, 0.64, 1), opacity 0.5s ease;
    }

    #details-card {
        transition: opacity 0.2s ease, transform 0.2s ease;
    }

    #details-card {
        transition: opacity 0.2s ease, transform 0.2s ease;
    }
</style>

<script>
    // Intersection Observer for animations
    document.addEventListener("DOMContentLoaded", () => {
        const observer = new IntersectionObserver((entries) => {
            entries.forEach(entry => {
                if (entry.isIntersecting) {
                    entry.target.classList.add('animate');
                    observer.unobserve(entry.target);
                }
            });
        }, { threshold: 0.1, rootMargin: "0px 0px -10% 0px" });

        document.querySelectorAll('.animate-on-scroll').forEach((el) => {
            observer.observe(el);
        });
        
        // --- STEP SWITCHER LOGIC ---
        const stepsData = [
  {
    "title": "Análise Termográfica",
    "desc": "Mapeamento aéreo e terrestre detalhado com câmeras térmicas de alta resolução para identificar pontos quentes (hotspots), rachaduras ocultas e falhas de conexão que prejudicam a geração.",
    "iconIndex": 0
  },
  {
    "title": "Inspeção Elétrica",
    "desc": "Verificação e reaperto de conexões elétricas, testes em inversores, string boxes, cabos e conectores MC4, garantindo segurança contra riscos de incêndio e arcos elétricos.",
    "iconIndex": 1
  },
  {
    "title": "Limpeza Técnica Avançada",
    "desc": "Lavagem profissional dos módulos utilizando água desmineralizada e escovas rotativas especializadas de cerdas macias, eliminando sujeiras, poeira e dejetos sem riscar os painéis.",
    "iconIndex": 2
  },
  {
    "title": "Emissão de Laudo",
    "desc": "Entrega de relatório técnico detalhado (Laudo de Performance) com diagnósticos, imagens termográficas, medições de eficiência e recomendações assinadas por engenheiros.",
    "iconIndex": 3
  }
];
        
        const stepItems = document.querySelectorAll('.step-item');
        const detailsTitle = document.getElementById('details-title');
        const detailsDesc = document.getElementById('details-desc');
        const detailIcons = document.querySelectorAll('.step-detail-icon');
        const detailsCard = document.getElementById('details-card');
        
        stepItems.forEach((item, index) => {
            item.addEventListener('click', () => {
                // Update active state in left column
                stepItems.forEach((el, elIndex) => {
                    const numberCircle = el.querySelector('div');
                    const icon = el.querySelector('svg');
                    
                    if (elIndex === index) {
                        // Make active
                        el.className = "step-item flex cursor-pointer transition-all duration-300 bg-white/5 rounded-lg p-4 shadow-xl backdrop-blur-md translate-x-[-10px] gap-x-4 items-center border border-white/10 relative z-10 group";
                        if (numberCircle) {
                            numberCircle.className = "w-8 h-8 shrink-0 rounded-full flex items-center justify-center text-xs font-bold transition-all bg-[#FDD017] text-black shadow-lg shadow-[#FDD017]/20 border-transparent";
                        }
                        if (icon) {
                            icon.setAttribute('class', "w-5 h-5 ml-auto shrink-0 transition-colors text-[#FDD017]");
                        }
                    } else {
                        // Make inactive
                        el.className = "step-item flex cursor-pointer transition-all duration-300 bg-white/5 rounded-lg p-4 shadow-xl backdrop-blur-md gap-x-4 items-center border border-white/5 hover:border-[#FDD017]/30 hover:translate-x-[-5px] group";
                        if (numberCircle) {
                            numberCircle.className = "w-8 h-8 shrink-0 rounded-full flex items-center justify-center text-xs font-bold transition-all bg-transparent border border-white/20 text-neutral-400 group-hover:text-yellow-400 group-hover:border-yellow-400";
                        }
                        if (icon) {
                            icon.setAttribute('class', "w-5 h-5 ml-auto shrink-0 transition-colors text-neutral-600 group-hover:text-white");
                        }
                    }
                });
                
                // Update right column content
                if (detailsTitle && detailsDesc && stepsData[index] && detailsCard) {
                    detailsCard.style.opacity = '0.3';
                    detailsCard.style.transform = 'scale(0.98)';
                    setTimeout(() => {
                        detailsTitle.textContent = stepsData[index].title;
                        detailsDesc.textContent = stepsData[index].desc;
                        
                        detailIcons.forEach((icon, iconIndex) => {
                            if (iconIndex === stepsData[index].iconIndex) {
                                icon.classList.remove('hidden');
                            } else {
                                icon.classList.add('hidden');
                            }
                        });
                        
                        detailsCard.style.opacity = '1';
                        detailsCard.style.transform = 'scale(1)';
                    }, 150);
                }
            });
        });
    });
</script>
