---
import Layout from "../layouts/Layout.astro";
import Header from "../components/sections/Header.astro";
import Hero from "../components/sections/Hero.astro";
import Diferenciais from "../components/sections/Diferenciais.astro";
import Servicos from "../components/sections/Servicos.astro";
import Sobre from "../components/sections/Sobre.astro";
import Contato from "../components/sections/Contato.astro";
import Footer from "../components/sections/Footer.astro";
---

<Layout>
    <Header />
    <main>
        <Hero />
        <Diferenciais />
        <Servicos />
        <Sobre />
        <Contato />
    </main>
    <Footer />
</Layout>

<script>
    // @ts-ignore
    window.addEventListener("load", () => {
        // @ts-ignore
        gsap.registerPlugin(TextPlugin, ScrollTrigger);

        // @ts-ignore
        const tl = gsap.timeline();

        // Cinematic slight zoom out on background video
        // @ts-ignore
        gsap.to("#video-bg video", {
            scale: 1,
            duration: 5,
            ease: "power2.out",
        });

        // Fade in Nav & Badge
        tl.to("#nav-animate, #badge-animate", {
            y: 0,
            opacity: 1,
            duration: 0.8,
            stagger: 0.2,
            ease: "power3.out",
            delay: 0.2,
        })
        // Typewriter Effect
        .to("#headline", {
            duration: 2.5,
            text: "Seu Investimento Solar Merece Evoluir.<br><span style='color: #FDD017;'>Nós Garantimos.</span>",
            ease: "none",
        })
        // Subheadline Slide Up
        .fromTo(
            "#subheadline",
            { y: 20, opacity: 0 },
            {
                y: 0,
                opacity: 1,
                duration: 0.8,
                ease: "back.out(1.2)",
            }
        )
        // CTA Button pop-in
        .fromTo(
            "#cta-animate",
            { scale: 0.9, opacity: 0 },
            {
                scale: 1,
                opacity: 1,
                duration: 0.6,
                ease: "back.out(1.5)",
            },
            "-=0.4"
        )
        // Scroll Indicator Fade In
        .fromTo(
            "#scroll-indicator",
            { y: -10, opacity: 0 },
            { y: 0, opacity: 1, duration: 0.6, ease: "power2.out" },
            "-=0.2"
        );

        // --- ALTA PERFORMANCE MOUSE FOLLOWER (GSAP QuickTo) ---
        const glowWrapper = document.querySelector(".solar-glow-wrapper");

        if (glowWrapper) {
            // Centraliza o ponto de origem no meio da div
            // @ts-ignore
            gsap.set(glowWrapper, { xPercent: -50, yPercent: -50 });

            // O quickTo foi desenhado especificamente pelo GSAP para seguir cursores em 60fps sem engasgos
            // @ts-ignore
            const xTo = gsap.quickTo(glowWrapper, "x", {
                duration: 0.8,
                ease: "power3.out",
            });
            // @ts-ignore
            const yTo = gsap.quickTo(glowWrapper, "y", {
                duration: 0.8,
                ease: "power3.out",
            });

            // Captura o movimento do mouse
            window.addEventListener("mousemove", (e) => {
                xTo(e.clientX);
                yTo(e.clientY);
            });

            // Centraliza o brilho de forma suave caso o usuário demore a mover o mouse no carregamento inicial
            xTo(window.innerWidth / 2);
            yTo(window.innerHeight / 2);
        }

        // Stop blinking cursor after a while
        setTimeout(() => {
            const cursor = document.querySelector(".typewriter-cursor") as HTMLElement | null;
            if (cursor) {
                cursor.style.opacity = "0";
                cursor.style.animation = "none";
            }
        }, 6000);

        // --- 2ª DOBRA: ANIMAÇÕES DE SCROLL (DIFERENCIAIS) ---



        // Montagem do Bento Box em Cascata
        // @ts-ignore
        gsap.to(".bento-item", {
            scrollTrigger: {
                trigger: "#bento-grid",
                start: "top 80%",
            },
            y: 0,
            opacity: 1,
            duration: 1,
            stagger: 0.15,
            ease: "expo.out",
            onComplete: () => {
                // Inicia animações internas após os cards montarem

                // Contador de suporte 24/7
                // @ts-ignore
                gsap.fromTo(
                    ".counter-time",
                    { textContent: "0" },
                    {
                        textContent: "24",
                        duration: 2,
                        snap: { textContent: 1 },
                        ease: "power2.out",
                    }
                );

                // Contador de Performance (100%)
                // @ts-ignore
                gsap.fromTo(
                    ".counter-perf",
                    { textContent: "0" },
                    {
                        textContent: "100",
                        duration: 4.5,
                        snap: { textContent: 1 },
                        ease: "power2.out",
                    }
                );

                // Efeito Líquido preenchendo o card
                // @ts-ignore
                gsap.fromTo(
                    ".liquid-fill",
                    { scaleY: 0, transformOrigin: "bottom" },
                    {
                        scaleY: 1,
                        duration: 4.5,
                        ease: "power2.inOut",
                        repeat: -1,
                        yoyo: true,
                        repeatDelay: 1.5,
                    }
                );
            },
        });

        // --- 3ª DOBRA: SERVIÇOS SCROLL ANIMATIONS ---
        // @ts-ignore
        gsap.to(".servicos-title", {
            scrollTrigger: {
                trigger: "#servicos",
                start: "top 75%",
            },
            y: 0,
            opacity: 1,
            duration: 1.2,
            ease: "power4.out",
        });

        // @ts-ignore
        gsap.to(".servico-item, .servico-indicator", {
            scrollTrigger: {
                trigger: "#servicos-grid",
                start: "top 80%",
            },
            y: 0,
            opacity: 1,
            duration: 1,
            stagger: 0.2,
            ease: "back.out(1.2)",
        });

        // --- BENTO GRID 3D HOVER EFFECT ---
        if (window.matchMedia("(hover: hover)").matches) {
            const bentoItems = document.querySelectorAll(".bento-item");

            bentoItems.forEach((item) => {
                // Configura perspectiva para o efeito 3D
                // @ts-ignore
                gsap.set(item, { transformPerspective: 1000 });

                item.addEventListener("mousemove", (e) => {
                    const mouseEvent = e as MouseEvent;
                    const rect = item.getBoundingClientRect();
                    // Posição do mouse relativa ao centro do card (-1 a 1)
                    const x = (mouseEvent.clientX - rect.left - rect.width / 2) / (rect.width / 2);
                    const y = (mouseEvent.clientY - rect.top - rect.height / 2) / (rect.height / 2);

                    // Rotaciona de forma equilibrada (máx 8 graus) e aplica scale sutil para elegância
                    // @ts-ignore
                    gsap.to(item, {
                        rotationY: x * 8,
                        rotationX: -y * 8,
                        scale: 1.02,
                        ease: "power2.out",
                        duration: 0.5,
                    });
                });

                item.addEventListener("mouseleave", () => {
                    // Efeito elástico ao soltar o card
                    // @ts-ignore
                    gsap.to(item, {
                        rotationY: 0,
                        rotationX: 0,
                        scale: 1,
                        ease: "elastic.out(1, 0.3)",
                        duration: 1.5,
                    });
                });
            });
        }

        // --- 4ª DOBRA: SOBRE NÓS SCROLL ANIMATIONS ---
        // @ts-ignore
        const mm = gsap.matchMedia();

        mm.add("(min-width: 768px)", () => {
            // Desktop: Linha da Timeline cresce na horizontal (width)
            // @ts-ignore
            gsap.to("#timeline-line", {
                scrollTrigger: {
                    trigger: ".timeline-container",
                    start: "top 80%",
                    end: "bottom 60%",
                    scrub: 1,
                },
                width: "100%",
                ease: "none",
            });
        });

        mm.add("(max-width: 767px)", () => {
            // Mobile: Linha da Timeline cresce na vertical (height)
            // @ts-ignore
            gsap.to("#timeline-line", {
                scrollTrigger: {
                    trigger: ".timeline-container",
                    start: "top 80%",
                    end: "bottom 60%",
                    scrub: 1,
                },
                height: "100%",
                ease: "none",
            });
        });

        // Títulos e Textos da Seção Sobre
        // @ts-ignore
        gsap.to(".sobre-title, .sobre-desc", {
            scrollTrigger: {
                trigger: "#sobre",
                start: "top 85%",
            },
            y: 0,
            opacity: 1,
            duration: 1.2,
            stagger: 0.2,
            ease: "power4.out",
        });

        // Nós da Timeline surgindo
        // @ts-ignore
        gsap.to(".timeline-node", {
            scrollTrigger: {
                trigger: ".timeline-container",
                start: "top 85%",
            },
            y: 0,
            opacity: 1,
            duration: 0.8,
            stagger: 0.3,
            ease: "back.out(1.5)",
        });

        // Bloco de Missão deslizando de baixo
        // @ts-ignore
        gsap.to(".missao-block", {
            scrollTrigger: {
                trigger: ".missao-block",
                start: "top 85%",
            },
            y: 0,
            opacity: 1,
            duration: 0.6,
            ease: "power4.out",
        });

        // Cards de Valores deslizando de baixo
        // @ts-ignore
        gsap.to(".valor-item", {
            scrollTrigger: {
                trigger: ".missao-block",
                start: "top 85%",
            },
            y: 0,
            opacity: 1,
            duration: 0.6,
            stagger: 0.2,
            ease: "back.out(1.2)",
        });

        // --- 5ª DOBRA: CONTATO SCROLL ANIMATIONS ---
        // @ts-ignore
        gsap.to(".contato-header", {
            scrollTrigger: {
                trigger: "#contato",
                start: "top 75%",
            },
            y: 0,
            opacity: 1,
            duration: 1.2,
            ease: "power4.out",
        });

        // @ts-ignore
        gsap.to(".contato-form", {
            scrollTrigger: {
                trigger: ".contato-form",
                start: "top 80%",
            },
            y: 0,
            opacity: 1,
            duration: 1,
            ease: "back.out(1.2)",
        });

        // @ts-ignore
        gsap.to(".contato-info", {
            scrollTrigger: {
                trigger: ".contato-info",
                start: "top 80%",
            },
            y: 0,
            opacity: 1,
            duration: 1,
            delay: 0.3,
            ease: "back.out(1.2)",
        });

        // --- FOOTER SCROLL ANIMATIONS ---
        // @ts-ignore
        gsap.to(".footer-col", {
            scrollTrigger: {
                trigger: "footer",
                start: "top 85%",
            },
            y: 0,
            opacity: 1,
            duration: 1,
            stagger: 0.15,
            ease: "back.out(1.2)",
        });

        // @ts-ignore
        gsap.to(".footer-bottom", {
            scrollTrigger: {
                trigger: "footer",
                start: "top 85%",
            },
            opacity: 1,
            duration: 1,
            delay: 0.6,
            ease: "power2.out",
        });

        // @ts-ignore
        ScrollTrigger.refresh();

        // Garante recalculo perfeito do posicionamento de todos os gatilhos no mobile real
        setTimeout(() => {
            // @ts-ignore
            ScrollTrigger.refresh();
        }, 300);
    });
</script>
